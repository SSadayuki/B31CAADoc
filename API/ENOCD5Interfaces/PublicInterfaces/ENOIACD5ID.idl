#include "CATIABase.idl"
interface CATIADocument;
interface IDispatch;

 /**
 * Represents the ENOVIA V6 Integration identifier.
 * <b>Role</b>: It identifies an ENOVIA V6 Object thanks to its Type/Name/Revision(/Version). It is managed by @href ENOIACD5Engine.
 * @see ENOIACD5Engine, ENOIACD5Structure
 */
interface ENOIACD5ID : CATIABase 
{

    /**
    * Returns the Identifier of the ENOVIA V6 Object associated to the CD5ID.
    * @return 
    * The identifier String of the ENOIACD5ID.
    * @sample
    * The following example returns in <tt>oID</tt> the identifier corresponding to the CD5ID <tt>oCD5ID</tt>.
    * <pre>
    * <font color="blue">Dim</font> oCD5Engine <font color="blue">As</font> CD5Engine
    * <font color="blue">Set</font> oCD5Engine = CATIA.GetItem("CD5Engine")
    * <font color="blue">Dim</font> oCD5ID <font color="blue">As</font> CD5ID
    * <font color="blue">Set</font> oCD5ID = oCD5Engine.<font color="blue">GetIDFromTNR</font>("CATProduct For Team", "MyProduct", "---")
    * <font color="blue">Dim</font> oID <font color="blue">As</font> CATBSTR
    * oID = oCD5ID.<font color="red">GetID</font>
    * </pre>
 */
    HRESULT GetID (inout /*IDLRETVAL*/ CATBSTR oID);

};

