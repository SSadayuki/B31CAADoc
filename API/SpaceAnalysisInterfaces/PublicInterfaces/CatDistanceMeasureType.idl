#ifndef CatDistanceMeasureType_IDL
#define CatDistanceMeasureType_IDL
/*IDLREP*/

/**
 * @CAA2Level L1
 * @CAA2Usage U3
 */

/**
 * The different types of distance measure.
 * It is used by the @href CATIADistance object to specify the measure type.
 * @param catDistanceMeasureTypeMinimum
 *   The computation measures the minimum distance between products
 * @param catDistanceMeasureTypeAlongX
 *   The computation measures the minimum distance along X between products
 * @param catDistanceMeasureTypeAlongY
 *   The computation measures the minimum distance along Y between products
 * @param catDistanceMeasureTypeAlongZ
 *   The computation measures the minimum distance along Z between products
 * @param catDistanceMeasureTypeBand
 *   The computation analyses the band between products
 */
enum CatDistanceMeasureType
{
  catDistanceMeasureTypeMinimum,
  catDistanceMeasureTypeAlongX,
  catDistanceMeasureTypeAlongY,
  catDistanceMeasureTypeAlongZ,
  catDistanceMeasureTypeBand
};

#endif
