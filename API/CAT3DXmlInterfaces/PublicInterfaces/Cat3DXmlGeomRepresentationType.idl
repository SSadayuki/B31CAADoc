#ifndef  Cat3DXmlGeomRepresentationType_IDL
#define  Cat3DXmlGeomRepresentationType_IDL
// COPYRIGHT DASSAULT SYSTEMES 2006
/*IDLREP*/  

/**
 * @CAA2Level L1
 * @CAA2Usage U3
 */
  
//  COPYRIGHT  Dassault  Systemes  2006
