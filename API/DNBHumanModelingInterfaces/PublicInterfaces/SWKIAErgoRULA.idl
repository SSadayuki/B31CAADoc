#include "CATIABase.idl"


/**
  *  This interface deals the RULA ergonomic analysis.
  **/
interface SWKIAErgoRULA : CATIABase
{
 // ===========================================================================
 //  get_ObjectWeight
 //  ----------------
 //  put_ObjectWeight
 //  ----------------
 //
    /**
      * Returns or sets the weight of the object being carried.
      **/
#pragma PROPERTY ObjectWeight
    HRESULT get_ObjectWeight(inout /*IDLRETVAL*/ CATBSTR pioObjectWeight);
    HRESULT put_ObjectWeight(in CATBSTR piObjectWeight);

 // ===========================================================================
 //  get_OverallScore
 //  -----------------
 //
    /**
      * This field is the overall RULA score, given the manikin's
      * current posture.
      **/
#pragma PROPERTY OverallScore
    HRESULT get_OverallScore(out /*IDLRETVAL*/ long poOverallScore);

// ===========================================================================
 //  get_Verdict
 //  -----------
 //
    /**
      * This field gives a text string which represents the
      * interpretaton of the overall RULA score.
      **/
#pragma PROPERTY Verdict
    HRESULT get_Verdict(inout /*IDLRETVAL*/ CATBSTR pioVerdict);

 // ===========================================================================
 //  get_ArmAbducted
 //  ---------------
 //
    /**
      * This property is <strong>True</strong> if the arm of the manikin is abducted,
      * given the manikin's current posture.
      **/
#pragma PROPERTY ArmAbducted
    HRESULT get_ArmAbducted(out /*IDLRETVAL*/ boolean poArmAbducted);

 // ===========================================================================
 //  get_ShoulderRaised
 //  ------------------
 //
    /**
      * This property is <strong>True</strong> if the shoulder of the manikin is raised,
      * given the manikin's current posture.
      **/
#pragma PROPERTY ShoulderRaised
    HRESULT get_ShoulderRaised(out /*IDLRETVAL*/ boolean poShoulderRaised);

 // ===========================================================================
 //  get_ArmOutToSide
 //  ----------------
 //
    /**
      * This property is <strong>True</strong> if the arm of the manikin is out to
      * the side, given the manikin's current posture.
      **/
#pragma PROPERTY ArmOutToSide
    HRESULT get_ArmOutToSide(out /*IDLRETVAL*/ boolean poArmOutToSide);

 // ===========================================================================
 //  get_WristBent
 //  -------------
 //
    /**
      * This property is <strong>True</strong> if the wrist of the manikin is bent,
      * given the manikin's current posture.
      **/
#pragma PROPERTY WristBent
    HRESULT get_WristBent(out /*IDLRETVAL*/ boolean poWristBent);

 // ===========================================================================
 //  get_WristTwisted
 //  ----------------
 //
    /**
      * This property is <strong>True</strong> if the wrist of the manikin is twisted,
      * given the manikin's current posture.
      **/
#pragma PROPERTY WristTwisted
    HRESULT get_WristTwisted(out /*IDLRETVAL*/ boolean poWristTwisted);

 // ===========================================================================
 //  get_NeckTwisted
 //  ---------------
 //
    /**
      * This property is <strong>True</strong> if the neck of the manikin is twisted,
      * given the manikin's current posture.
      **/
#pragma PROPERTY NeckTwisted
    HRESULT get_NeckTwisted(out /*IDLRETVAL*/ boolean poNeckTwisted);

 // ===========================================================================
 //  get_NeckSideBending
 //  -------------------
 //
    /**
      * This property is <strong>True</strong> if the neck of the manikin is bent,
      * given the manikin's current posture.
      **/
#pragma PROPERTY NeckSideBending
    HRESULT get_NeckSideBending(out /*IDLRETVAL*/ boolean poNeckSideBending);

 // ===========================================================================
 //  get_TrunkTwisted
 //  ----------------
 //
    /**
      * This property is <strong>True</strong> if the trunk of the manikin is twisted,
      * given the manikin's current posture.
      **/
#pragma PROPERTY TrunkTwisted
    HRESULT get_TrunkTwisted(out /*IDLRETVAL*/ boolean poTrunkTwisted);

 // ===========================================================================
 //  get_TrunkSideBending
 //  --------------------
 //
    /**
      * This property is <strong>True</strong> if the trunk of the manikin is bent,
      * given the manikin's current posture.
      **/
#pragma PROPERTY TrunkSideBending
    HRESULT get_TrunkSideBending(out /*IDLRETVAL*/ boolean poTrunkSideBending);
};

// Interface name : SWKIAErgoRULA
#pragma ID SWKIAErgoRULA "DCE:9679a170-4207-11d4-a223000629753ac1"
#pragma DUAL SWKIAErgoRULA

// VB object name : SWKErgoRULA (Id used in Visual Basic)
#pragma ID SWKErgoRULA "DCE:9e74ab20-4207-11d4-a223000629753ac1"
#pragma ALIAS SWKIAErgoRULA SWKErgoRULA

#endif
