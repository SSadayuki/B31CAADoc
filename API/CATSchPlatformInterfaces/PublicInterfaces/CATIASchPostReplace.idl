#include "CATIABase.idl"

 /** 
  * Manage post component replacement behaviors.
  */

interface CATIASchPostReplace : CATIABase
{
  /**
  * Handle associated annotations after replace.
  * @param iNewSchObject
  *   Pointer to the object that is replacing 'this' object.
  *    
  * @sample
  * <pre>
  * Dim objThisIntf As SchPostReplace
  * Dim objArg1 As AnyObject
  *  ...
  * objThisIntf.<font color="red">PostReplaceText</font>objArg1
  * </pre>
  *    
  */
  HRESULT PostReplaceText ( 
    in CATIABase iNewSchObject );
    
};
    
