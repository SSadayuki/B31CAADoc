/**
 * Schematic route gap style.
 * <b>Role</b>: Indicates which gap style to display at route intersections.
 * @param catSchIDLBlankGap
 *   Use a space to represent the gap.
 * @param catSchIDLJumpGap
 *   Use a jump symbol to represent the gap.
 * @param catSchIDLWavyGap
 *   Use a wavy symbol to represent the gap.
 */
enum CatSchIDLGapStyle
{
  catSchIDLBlankGap,
  catSchIDLJumpGap,
  catSchIDLWavyGap
};


#endif
