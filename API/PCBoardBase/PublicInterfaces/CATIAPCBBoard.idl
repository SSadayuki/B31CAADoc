#include "CATBaseDispatch.idl"
#include "CATIABase.idl"	
#include "CATBSTR.idl"
interface CATIAPad;
interface CATIAHole;
interface CATIAPattern;
 
 /** 
   interface to manage the representation of a CBD product object.
  */

interface CATIAPCBBoard : CATIABase
{
 /**
  * set the pad of a Board or a component or a panel.
  *  
  */
#pragma PROPERTY Part
  HRESULT get_Part(out /*IDLRETVAL*/ CATIAPad oPad);   
  HRESULT put_Part(in  CATIAPad iPad);
  
       
  /**
   *
   *  This method allows to add a constraint area to a board.
   * @param zonetype
   * This parameter represents the type of the zone to create
   * The differents values are ROUTE_OUTLINE, PLACE_OUTLINE, OTHER_OUTLINE,
   * VIA_KEEPOUT, PLACE_KEEPOUT, PLACE_REGION, ROUTE_KEEPOUT
   * @return <UL> 
   *         <LH>The result of the method:
   *         <LI>S_OK if succeeded
   *         <LI>E_FAIL if failed
   *         </UL> 
   */

  HRESULT create_zone(in CATBSTR zonetype,in  CATIAPad iPad);


//----------------------------------------------------------------------------------
  /**
  * Allow to get and set the attribute owner of a Panel or a Board
  * The possible  values  are MCAD, ECAD, UNKNOWN
  * @return <UL> 
  *         <LH>The result of the method:
  *         <LI>S_OK if succeeded
  *         <LI>E_FAIL if failed
  *         </UL> 
  */
#pragma PROPERTY Owner
  HRESULT get_Owner(out /*IDLRETVAL*/ CATBSTR  oOwner);   
  HRESULT put_Owner(in  CATBSTR iOwner);
  
          
//----------------------------------------------------------------------------------
  /**
   *
   *  This method allows to add a Pcb hole to a board or a panel. 
   * 
   * @param iHole
   * This parameter represents the hole to transform in Pcb hole
   *
   * @param iplatingStyle 
   * This parameter represents the plating style of the hole.  
   * The differents values are  PTH or NPTH
   *
   * @param iAssociatedPartName
   * This parameter represents name of the associated part to the hole. 
   * The possible values are : 
   *    the name of the instance of component in which the hole is defined. 
   *    BOARD if the hole is defined in the Board part
   *    PANEL If the hole is defined in the Panel part
   *    NOREFDES is the hole is defined in a non Electronic Part. 
   *
   * @param iHoleType
   * This parameter represents the function of the hole. 
   * The differents values are :
   *    PIN if the hole is associated with a component pin
   *    VIA if the hole is associated with  a conductive via
   *    MTG if the hole is used for mounting purposes
   *    TOOL if the hole is used for tooling purposes
   *    Other  ( User defined ) 
   *
   * @param iHoleOwner
   * The parameter represents the owner of the hole. 
   * The possible values are : MCAD, ECAD, UNOWNED
   *
   * @return <UL> 
   *         <LH>The result of the method:
   *         <LI>S_OK if succeeded
   *         <LI>E_FAIL if failed
   *         </UL> 
   */

  HRESULT create_pcbhole ( in CATIAHole iHole, in CATBSTR iplatingStyle, in CATBSTR iAssociatedPartName, in CATBSTR iHoleType, in CATBSTR iHoleOwner); 

	   //----------------------------------------------------------------------------------
  /**
   *
   *  This method allows to add a Pcb pattern of hole to a board or a panel. 
   *  If the motif hole of the pattern is pcb hole, the input value are not taken into account
   *  
   * @param iPattern
   * This parameter represents the Pattern  to transform in Pcb Pattern 
   *
   * @param iplatingStyle 
   * This parameter represents the plating style of the hole.  
   * The differents values are  PTH or NPTH
   *
   * @param iAssociatedPartName
   * This parameter represents name of the associated part to the hole. 
   * The possible values are : 
   *    the name of the instance of component in which the hole is defined. 
   *    BOARD if the hole is defined in the Board part
   *    PANEL If the hole is defined in the Panel part
   *    NOREFDES is the hole is defined in a non Electronic Part. 
   *
   * @param iHoleType
   * This parameter represents the function of the hole. 
   * The differents values are :
   *    PIN if the hole is associated with a component pin
   *    VIA if the hole is associated with  a conductive via
   *    MTG if the hole is used for mounting purposes
   *    TOOL if the hole is used for tooling purposes
   *    Other  ( User defined ) 
   *
   * @param iHoleOwner
   * The parameter represents the owner of the hole. 
   * The possible values are : MCAD, ECAD, UNOWNED
   *
   * @return <UL> 
   *         <LH>The result of the method:
   *         <LI>S_OK if succeeded
   *         <LI>E_FAIL if failed
   *         </UL> 
   */

  HRESULT create_pcbpattern ( in CATIAPattern iPattern, in CATBSTR iplatingStyle, in CATBSTR iAssociatedPartName, in CATBSTR iHoleType, in CATBSTR iHoleOwner);

//-----------------------------------------------------------------------------

};

// Interface name : CATIAPCBBoard
#pragma ID CATIAPCBBoard "DCE:962fb008-7b27-11d3-ab7b006094eb39d9"
#pragma DUAL CATIAPCBBoard

// VB object name : PCBBoard
#pragma ID PCBBoard "DCE:c5db717a-7b3b-11d3-ab7b006094eb39d9"
#pragma ALIAS CATIAPCBBoard PCBBoard

#endif
