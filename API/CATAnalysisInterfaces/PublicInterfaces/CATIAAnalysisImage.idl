#ifndef CATIAAnalysisImage_IDL
#define CATIAAnalysisImage_IDL
/*IDLREP*/

//=================================================================
// COPYRIGHT DASSAULT SYSTEMES 2002
//=================================================================
//                                   
// CATIAAnalysisImage:                           
// Exposed interface for Analysis Image
//                                   
//=================================================================
// Usage notes:
//
//=================================================================
