#include "CATIABase.idl"
#include "CATIAAnalysisPostManager.idl"
#include "CATIAAnalysisAdaptivityManager.idl"
#include "CATIAAnalysisCases.idl"
#include "CATIAAnalysisSets.idl"
#include "CATIAAnalysisMeshManager.idl"
#include "CATIAAnalysisMeshParts.idl"

interface CATIAAnalysisCases;
interface CATIAAnalysisSets;    

/**  
 * Represent the  analysis model object.
 * <b>Role</b>: In the analysis document, an analysis model is the object
 * dedicated to set and manage all the required data for the discretization 
 * and idealization of a Finite Element model. <br>
 * This object gives access to:
 * <ul>
 * <li> A collection of AnalysisCase.</li>
 * <li> A collection of AnalysisSets (All the input sets like properties, groups).</li>
 * <li> A AnalysisPostManager object for reporting.</li>
 * </ul>
 */
interface CATIAAnalysisModel : CATIABase 
{
/**
 * Returns the collection of analysis cases defined on the analysis model.
 * @return oAnalysisCases Collection of cases.
 */
#pragma PROPERTY AnalysisCases
	HRESULT get_AnalysisCases(out /*IDLRETVAL*/ CATIAAnalysisCases oAnalysisCases);
/**
 * Returns the analysis sets collection associated with a analysis model.
 * @return a collection of  CATIAAnalysisSets.
 */
#pragma PROPERTY AnalysisSets
	HRESULT get_AnalysisSets(out /*IDLRETVAL*/ CATIAAnalysisSets oAnalysisSets);

/**
 * Returns the Postprocessing  manager defined on the analysis model.
 * @return oPostManager the AnalysisPostManager Object.
 */
#pragma PROPERTY PostManager
	HRESULT get_PostManager(out /*IDLRETVAL*/ CATIAAnalysisPostManager oPostManager);


/**
 * Apply a transition to the analysis model.
 * @param Transition name.
 */
	HRESULT RunTransition(in CATBSTR iTransitionName);

/**
 * Returns the AdaptivityManager defined on the analysis model.
 * @return a CATIAAnalysisAdaptivityManager.
 */
#pragma PROPERTY AdaptivityManager
	HRESULT get_AdaptivityManager(out /*IDLRETVAL*/ CATIAAnalysisAdaptivityManager oAdaptivityManager);

/**
 * Returns the MeshManager defined on the analysis model.
 * @return a CATIAAnalysisMeshManager.
 */
#pragma PROPERTY MeshManager
	HRESULT get_MeshManager(out /*IDLRETVAL*/ CATIAAnalysisMeshManager oMeshManager);

};

