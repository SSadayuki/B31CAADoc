#ifndef CATIAPspListOfBSTRs_IDL
#define CATIAPspListOfBSTRs_IDL

/*IDLREP*/

//	COPYRIGHT DASSAULT SYSTEMES 2004

/**
 * @CAA2Level L1
 * @CAA2Usage U3
 */


#include "CATIABase.idl"

/**
 * Represents a collection of CATBSTR type  of strings.
 * <b>Role</b>: Collection of CATBSTR type  of strings.
 */

interface CATIAPspListOfBSTRs : CATIABase
{
  /**
   * Returns the number of character strings in the list.
   * <! @sample >
   * <dl>
   * <dt><b>Example:</b>
   * <dd>
   * This example retrieves in  <tt>NumberOfStrings</tt> the number of character strings
   * currently gathered in <tt>MyList</tt>.
   * <pre>
   * Dim NumberOfStrings As long
   * NumberOfStrings = MyList.<font color="red">Count</font>
   * </pre>
   * </dl>
   */
#pragma PROPERTY Count
  HRESULT get_Count (out /*IDLRETVAL*/ long oNbItems);

  /**
   * Returns a character string from its index in the list.
   * @param iIndex
   *   The index of the first character string in the collection is 1, and
   *   the index of the last character string is Count.	 
   * @return the retrieved string.
   *
   * @sample
   * The following example returns the third character string in the list.
   * <pre>
   * Dim MyStr As String
   * Dim MyList As PspListOfBSTRs
   * MyStr = PspListOfBSTRs.<font color="red">Item</font>(3)
   * </pre>
   */
  HRESULT Item (in long iIndex,  inout /*IDLRETVAL*/ CATBSTR oBSTR);

  /**
   * Adds a character string to the end of the list.
   * @param iBSTR
   *   The character string to be added to the list.
   *
   * @sample
   * The following example appends a string to the list.
   * <pre>
	 * Dim MyList As PspListOfBSTRs
   * MyList.<font color="red">Append</font>("MyString")
   * </pre>
   */
  HRESULT Append (in CATBSTR iBSTR);

  /**
   * Remove a character string from the list by specifying its position in the list.
   * @param iIndex
   *   The position of the character string to be removed in the list.
   *
   * @sample
   * The following example removes the second entry in the list. Please note that the
	 * list index starts with 1.
   * <pre>
	 * Dim MyList As PspListOfBSTRs
   * MyList.<font color="red">Remove</font>(2)
   * </pre>
   */

  HRESULT RemoveByIndex (in long iIndex);

};

// Interface name : CATIAPspListOfBSTRs
#pragma ID CATIAPspListOfBSTRs "DCE:58964b87-a6c1-4f92-bbb2ff60cdf422db"                                    
#pragma DUAL CATIAPspListOfBSTRs

// VB object name : PspListOfBSTRs
#pragma ID PspListOfBSTRs "DCE:b1f82f17-e225-4440-bb96a80f80d1e60c"                               
#pragma ALIAS CATIAPspListOfBSTRs PspListOfBSTRs

#endif
