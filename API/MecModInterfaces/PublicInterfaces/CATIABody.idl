#ifndef CATIABody_IDL
#define CATIABody_IDL
/*IDLREP*/

/**
 * @CAA2Level L1
 * @CAA2Usage U3
 */

//=================================================================
// COPYRIGHT DASSAULT SYSTEMES 1997
//=================================================================
//                                   
// CATIABody:                           
// Exposed interface for Body
//                                   
