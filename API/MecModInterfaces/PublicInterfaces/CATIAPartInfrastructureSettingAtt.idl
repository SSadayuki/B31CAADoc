   */
  HRESULT GetBodiesUnderOperationsInTreeInfo(inout					    CATBSTR ioAdminLevel,
                                   inout					    CATBSTR ioLocked,
                                   out  /*IDLRETVAL*/	boolean oModified);

  /**
