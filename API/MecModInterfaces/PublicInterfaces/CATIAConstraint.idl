#include "CATIABase.idl"
#include "CATIAReference.idl"
#include "CATConstraintType.idl"
#include "CATConstraintMode.idl"
#include "CATConstraintStatus.idl"
#include "CATConstraintSide.idl"
#include "CATConstraintDistConfig.idl"
#include "CATConstraintDistDirection.idl"
#include "CATConstraintRefAxis.idl"
#include "CATConstraintRefType.idl"
#include "CATConstraintOrientation.idl"
#include "CATConstraintAngleSector.idl"
#include "CATSafeArray.idl"


interface CATIAGeometricElement;
interface CATIADimension;

/**
 * A geometric constraint set for geometric elements of a part, a sketch,
 * or a product.
 */
interface CATIAConstraint : CATIABase
{
	//		================
	//		== PROPERTIES ==
	//		================
    /**
     * Returns the  constraint type.
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example returns in <tt>cstType</tt> the type 
     * of the <tt>firstCst</tt> constraint:
     * <pre>
     * cstType = firstCst.<font color="red">Type</font>
     *</pre>
     * </dl>
     */
#pragma PROPERTY Type
	HRESULT   get_Type(out /*IDLRETVAL*/  CatConstraintType   oType);

    /**
     * Returns the constraint dimension.
     * The dimension may be meaningless for some types of constraints 
     * such as tangency constraints, 
     * or if the constraint is not currently satisfied.
     * Use the @href #Status property to check whether the constraint is 
     * satisfied.
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example returns in <tt>cstDimension</tt> the dimension 
     * of the <tt>firstCst</tt> constraint:
     * <pre>
     * Set cstDimension = firstCst.<font color="red">Dimension</font>
     * </pre>
     * </dl>
     */
#pragma PROPERTY Dimension
	HRESULT   get_Dimension(out /*IDLRETVAL*/ CATIADimension  oDimension);

    /**
     * Returns or sets the constraint driving  mode. 
     * For constraint types supporting the concept of value, such as distance 
     * constraints, the driving mode tells whether the constraint value
     * actually drives the geometry position, or, conversely, is driven 
     * by it.
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example retrieves in <tt>currentMode</tt>
     * the driving mode for the <tt>distCst</tt> distance constraint: 
     * <pre>
     * currentMode = distCst.<font color="red">Mode</font>
     *</pre>
     * </dl>
     */
#pragma PROPERTY Mode
	HRESULT   get_Mode(out /*IDLRETVAL*/    CatConstraintMode  oMode);
	HRESULT   put_Mode(in    CatConstraintMode   iNewMode);

    /**
     * Returns or sets the constraint side. 
     * Some constraint types need to relatively position
     * the constrained geometries, when several possible configurations
     * are all satisfying the constraint. 
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example retrieves in <tt>distCstSide</tt> the side
     * of the <tt>distCst</tt> distance constraint: 
     * <pre>
     * distCstSide = distCst.<font color="red">Side</font>
     *</pre>
     * </dl>
     */
#pragma PROPERTY Side 
	HRESULT   get_Side(out /*IDLRETVAL*/ CatConstraintSide oCurrentSide);
	HRESULT   put_Side(in  CatConstraintSide iNewSide);

    /**
     * Returns or sets the constraint orientation.
     * This is used for constraints that involve  two 
     * geometric elements and specifies the orientation for the
     * second geometric element with regard to the first one, when several 
     * possible orientations are all satisfying the constraint.  
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example retrieves the in <tt>distCstOrient</tt>
     * the orientation of the <tt>distCst</tt> distance constraint:
     * <pre>
     * distCstOrient = distCst.<font color="red">Orientation</font>
     * </pre>
     * </dl>
     */
#pragma PROPERTY Orientation 
	HRESULT   get_Orientation
                    (out /*IDLRETVAL*/ CatConstraintOrientation oOrient);
	HRESULT   put_Orientation
                    (in CatConstraintOrientation iNewOrient);

    /**
     * Returns or sets the distance constraint configuration.
     * Distance constraints between lines and cylinders offer 
     * often more degrees of freedom to geometry than acually desired.
     * This property allows to limit these degrees of freedom without 
     * having to redefine additional constraints.
     * This property is useless for constraints whose type is not distance. 
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example retrieves in <tt>distCstConfig</tt>
     * the configuration of the <tt>distCst</tt> distance constraint:
     * <pre>
     * distCstConfig = distCst.<font color="red">DistanceConfig</font>
     * </pre>
     * </dl>
     */
#pragma PROPERTY DistanceConfig 
	HRESULT   get_DistanceConfig
                    (out /*IDLRETVAL*/ CatConstraintDistConfig oCurrentConf);
	HRESULT   put_DistanceConfig
                    (in CatConstraintDistConfig iNewConfig);
    /**
     * Returns or sets the distance constraint direction.
     * This property is useless for constraints whose type is not Distance (1).
	 * Distance constraints may be measured along a particular direction.
	 * This property will be  used if the direction is a reference axis :
	 * In 2D, 1 means the horizontal axis, 2 the vertical axis.  
     * In 3D, 1 stands for the X axis, 2 for the Y axis, 3 for the Z axis.
	 * 0 means that no direction is specified and the distance is measured as usual.
	 *
	 *
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example retrieves in <tt>distCstDirection</tt>
     * the configuration of the <tt>distCst</tt> distance constraint:
     * <pre>
     * distCstConfig = distCst.<font color="red">DistanceDirection</font>
     * </pre>
     * </dl>
     */

#pragma PROPERTY DistanceDirection
	HRESULT   get_DistanceDirection
                    (out /*IDLRETVAL*/ CatConstraintDistDirection oCurrentDirection);
	HRESULT   put_DistanceDirection
                    (in CatConstraintDistDirection iNewDirection);

    /**
     * Returns or sets the constraint angle (or angular) sector.
     * The geometric elements of an angle constraint 
     *	(e.g. : 2 lines or 2 planes)
     * divide the sketch or the space in 4 regions which are called angle
     * or angular sectors, numbered from 0 to 3.
     *      
     *  1  / 0
     * ---/--- 
     *  2/   3
     *
     * By default, the constraint is created in the sector number 0.
     * One angle sector corresponds exactly to particular values 
     * of the Dimension.Value, the Side and the Orientation.
     * When changing the angle sector, the Dimension.Value, 
     * Side and Orientation are also modified.  
     * 
     * @param AngleSector=0
     *    The default sector of a constraint.      
     *        Dimension.Value = angle 
     *        Orientation     = catCstOrientSame
     *        Side            = catCstSidePositive
     * @param AngleSector=1
     *        Dimension.Value = angle-180 if angle>180
     *                         abs(angle)+180 otherwise
     *        Orientation     = catCstOrientOpposite
     *        Side            = catCstSidePositive
     * @param AngleSector=2
     *        Dimension.Value = abs(540-angle) if angle>180
     *                         180-fabs(angle) otherwise
     *        Orientation     = catCstOrientOpposite
     *        Side            = catCstSideNegative
     * @param AngleSector=3
     *        Dimension.Value = 360-abs(angle)
     *        Orientation     = catCstOrientSame
     *        Side            = catCstSideNegative
     *
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example retrieves in <tt>angleSector</tt>
     * the angle sector of the <tt>angleCst</tt> angle constraint
     * and then changes the angle sector
     * <pre>
     * angleSector = angleCst.<font color="red">AngleSector</font>
     * angleCst.AngleSector = 2
     * </pre>
     * </dl>
     */
#pragma PROPERTY AngleSector 
	HRESULT   get_AngleSector
                    (out /*IDLRETVAL*/ CatConstraintAngleSector oCurrentSector);
	HRESULT   put_AngleSector
                    (in CatConstraintAngleSector iNewSector);

    /**
     * Returns or sets the constraint reference axis.
     * AxisParallel or AxisPerpendicular constraint types define which
     * axis they relate to through this property, 
     * which makes no sense for constraints of another type.
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example retrieves in <tt>refAxis</tt> the reference
     * axis for the <tt>axisPerpCst</tt> AxisPerpendicular constraint: 
     * <pre>
     * refAxis = axisPerpCst.<font color="red">ReferenceAxis</font>
     * </pre>
     * </dl>
     */
#pragma PROPERTY ReferenceAxis 
	HRESULT   get_ReferenceAxis
                    (out /*IDLRETVAL*/ CatConstraintRefAxis oCurrentRefAxis);
	HRESULT   put_ReferenceAxis
                    (in CatConstraintRefAxis iNewRefAxis);

    /**
     * Returns or sets the constraint reference type.
	 * This property is used only for Reference constraints in the Assembly context.
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example applies to the reference constraint refCst2
	 * the reference type of the constraint refCst1. 
     * <pre>
     * refCst2.ReferenceType = refCst1.<font color="red">ReferenceType</font>
     * </pre>
     * </dl>
     */
#pragma PROPERTY ReferenceType 
	HRESULT   get_ReferenceType
                    (out /*IDLRETVAL*/ CatConstraintRefType oCurrentRefType);
	HRESULT   put_ReferenceType
                    (in CatConstraintRefType iNewRefType);

   
    /**
     * Returns the constraint status.
     * The constraint status is a diagnosis on whether the constraint
     * is satisfied.
     * <! @sample >
     * <dl>
     * <dt><b>Example:</b>
     * <dd>The following example retrieves the status of the <tt>distCst</tt>
     * distance constraint. 
     * <pre>
     * distCstSts = distCst.<font color="red">Status</font>
     *</pre>
     * </dl>
     */
#pragma PROPERTY Status 
	HRESULT   get_Status(out /*IDLRETVAL*/ CatConstraintStatus oStatus);


        //
	//		================
	//		==   METHODS  ==
	//		================

    /**
     * Returns the constraint visualisation location.
     * When displayed on screen, the constraint is visualized as 
     * a dimension positioned close to the constrained geometric element(s).
     * This method retrieves the data used to position this representation
     * within the 3D space. 
     * @param oAnchorPoint
     *   A Safe Array made up of 3 doubles: X, Y, Z, representing the 
     *   coordinates in model space of the point where the constraint value 
     *   is displayed.
     * @param oAnchorVector  
     *   A Safe Array made up of 3 doubles : X, Y, Z, representing the 
     *   vector normal to the plane onto which the constraint value 
     *   is displayed. 
     * <! @sample >
     * </dl>
     * <dt><b>Example:</b>
     * <dd>The following example retrieves in <tt>anchorPt</tt> the anchor point
     * of the <tt>tangencyCst</tt> tangency constraint:
     * <pre>
     * Dim anchorPoint(2)
     * Dim anchorVector(2)
     * tangencyCst.<font color="red">ConstraintVisuLocation</font> anchorPoint,vectorPoint
     *</pre>
     * </dl>
     */
	HRESULT   GetConstraintVisuLocation
                     (inout CATSafeArrayVariant oAnchorPoint,
                      inout CATSafeArrayVariant oAnchorVector);
    /**
     * Sets a new location for the constraint visualization.
     * @param  iNewX
     *   The new value for the constraint anchor point X coordinate
     * @param  iNewY
     *   The new value for the constraint anchor point Y coordinate
     * @param  iNewZ
     *   The new value for the constraint anchor point Z coordinate
     * <! @sample >
     * </dl>
     * <dt><b>Example:</b>
     * <dd>The following example changes the anchor point coordinates to 10,0,0
     * <pre>
     * tangencyCst.<font color="red">SetConstraintVisuLocation</font> 10,0,0
     *</pre>
     * </dl>
     */
	HRESULT   SetConstraintVisuLocation(in  double iNewX,
                                        in  double iNewY,      
										in double iNewZ);  
   /**
     * Reads an element of a constraint.
	 *  
     * @param  iElementNumber
     *   The number of the element of the constraint to be read.
	 *   (1 for the first element,2 for the second, 3 for the third).
	 *   Notice it must not exceed the total number of elements of the constraint.
	 *   (eg : not allowed to read the third element of a tangency).
	 *  
	 * @param  oCurrentElement
	 *   An element of the constraint.
	 * 
	 * <! @sample >
     * </dl>
     * <dt><b>Example:</b>
     * <dd>The following example reads the first element of a constraint
	 * <pre>
	 * Dim reference1 As Reference
     * reference1=tangencyCst.<font color="red">GetConstraintElement</font>( 1 )
     *</pre>
     * </dl>
     */
	HRESULT   GetConstraintElement(in  long iElementNumber,
                                   out /*IDLRETVAL*/ CATIAReference oCurrentElement);
   /**
     * Replaces an element of a constraint.
	 *  
     * @param  iElementNumber
     *   The number of the element of the constraint to replace.
	 *   (1 for the first element,2 for the second, 3 for the third).
	 *  
	 * @param  iNewElement
	 *   A new element of the constraint.
	 * 
	 * <! @sample >
     * </dl>
     * <dt><b>Example:</b>
     * <dd>The following example changes the second element of a constraint
	 * <pre>
	 * Dim reference1 As Reference
     * tangencyCst.<font color="red">SetConstraintElement</font> ( 2, reference1)
     *</pre>
     * </dl>
     */
	HRESULT   SetConstraintElement(in  long iElementNumber,
                                   in  CATIAReference iNewElement);

    //
    //  Deactivates a constraint
    //  ------------------------
    /**
     * Suppresses the constraint from being updated.
     * A deactivated constraint is not taken into account 
     * for the calculation of the part or of the product.
     * <! @sample >
     * </dl>
     * <dt><b>Example:</b>
     * <dd>The following example deactivates the <tt>tangencyCst</tt> constraint
     * from being updated:
     * <pre>
     * tangencyCst.Deactivate
     *</pre>
     * </dl>
     */
    HRESULT    Deactivate();
						     
    //
    //  Reactivates a constraint
    //  ------------------------
    /**
     * Unsuppresses a constraint for the update process.
     * An activated constraint is again taken into account 
     * for the calculation of the part or product.
     * <dt><b>Example:</b>
     * <dd>The following example es the <tt>pad1</tt> pad:
     * <dt><b>Example:</b>
     * <dd>The following example activates the <tt>tangencyCst</tt> constraint :
     * <pre>
     * tangencyCst.Activate
     *</pre>
     * </dl>
     */
    HRESULT    Activate ();
						   

    //
    //  Active status of a constraint
    //  -----------------------------
    /**
     * Indicates whether a constraint is suppressed from the update process.
     * A suppressed constraint is not taken into account for the calculation of part or 
	 * the product.
	 * The method returns True if the constraint is not active, 
	 * False if the constraint is active.
     * <dt><b>Example:</b>
     * <dd>The following example returns in <tt>isInactive</tt>
     * whether the <tt>tangencyCst</tt> constraint is suppressed from the update process:
     * <pre>
     * Set isInactive = tangencyCst.<font color="red">IsInactive</font>
     *</pre>
     * </dl>
     */
    HRESULT    IsInactive( out /*IDLRETVAL*/ boolean oValue );

};

// Interface name : CATIAConstraint
#pragma ID CATIAConstraint "DCE:cac0042a-6bd0-11d1-a2800000f87546fd"
#pragma DUAL CATIAConstraint

// VB object name : Constraint (Id used in Visual Basic)
#pragma ID Constraint "DCE:caf0e45f-6bd0-11d1-a2800000f87546fd"
#pragma ALIAS CATIAConstraint Constraint


#endif // CATIAConstraint_IDL

