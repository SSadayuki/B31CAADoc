# 
IMPACT_ON_IMPORT = YES
#
COMDYN_MODULE = V4SysCOMD
#
BUILT_OBJECT_TYPE = SHARED LIBRARY
#
OS = COMMON
LINK_WITH = V4SysUTIL CATIAEntity CATIAUDB2 CATIAMAO
SYS_LIBPATH = 

#------------------------------------------------------
OS = AIX
#------------------------------------------------------
SYS_LIBS = -lxlf -lxlf90 -lxlfpad

#------------------------------------------------------
OS = IRIX
#------------------------------------------------------
SYS_LIBS = -lftn

#------------------------------------------------------
OS = HP-UX
#------------------------------------------------------
#if os hpux_a
# libf or libcl is for HP 10.20 libF90 for HP 11
SYS_LIBS = -lf
#else
SYS_LIBS = -lF90
#endif

#------------------------------------------------------
OS = hpux_b64 
#------------------------------------------------------
#if os hpux_a
# libf or libcl is for HP 10.20 libF90 for HP 11
SYS_LIBS = -lf
#else
SYS_LIBS = -lF90 -lcps 
#endif

#------------------------------------------------------
OS = SunOS
#------------------------------------------------------
SYS_LIBS = -lF77
SYS_LIBPATH =

#------------------------------------------------------
OS = Windows_NT
#------------------------------------------------------

#------------------------------------------------------
OS = intel_a64
#------------------------------------------------------
SYS_LIBS = 

#------------------------------------------------------
OS = win_a
#------------------------------------------------------
BUILD = YES
LOCAL_CCFLAGS = -D_WIN98_SOURCE
