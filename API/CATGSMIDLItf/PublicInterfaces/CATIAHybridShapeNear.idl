#include "CATIAHybridShape.idl"
#include "CATIAReference.idl"

/**
 * The Near feature : an Near is made up of a face to process
 * and one Near parameter.
 */

//-----------------------------------------------------------------
interface CATIAHybridShapeNear : CATIAHybridShape
{
#pragma PROPERTY MultipleSolution





 /**
 * <b>Role</b>: To get_MultipleSolution on the object. 
 * @param oMultipleSolution 
 *   multiple element  
 *   return value for CATScript applications, with (IDLRETVAL) function type
 *   @see CATIAReference 
 * @return HRESULT 
 *   S_OK   if Ok 
 *   E_FAIL else 
 *   return error code for C++ Implementations
 * @see CATIAHybridShapeFactory 
 */ 
 HRESULT  get_MultipleSolution (out /*IDLRETVAL*/ CATIAReference   oMultipleSolution);





 /**
 * <b>Role</b>: To put_MultipleSolution on the object. 
 * @param iMultipleSolution 
 *   multiple element
 *   @see CATIAReference 
 * @return HRESULT 
 *   S_OK   if Ok 
 *   E_FAIL else 
 *   return error code for C++ Implementations
 * @see CATIAHybridShapeFactory 
 */ 
 HRESULT  put_MultipleSolution (in     CATIAReference   iMultipleSolution);

#pragma PROPERTY ReferenceElement





 /**
 * <b>Role</b>: To get_ReferenceElement on the object. 
 * @param oRefElem 
 *   reference element 
 *   return value for CATScript applications, with (IDLRETVAL) function type
 *   @see CATIAReference 
 * @return HRESULT 
 *   S_OK   if Ok 
 *   E_FAIL else 
 *   return error code for C++ Implementations
 * @see CATIAHybridShapeFactory 
 */ 
 HRESULT get_ReferenceElement (out /*IDLRETVAL*/ CATIAReference   oRefElem);





 /**
 * <b>Role</b>: To put_ReferenceElement on the object. 
 * @param iRefElem 
 *   reference element   
 *   @see CATIAReference 
 * @return HRESULT 
 *   S_OK   if Ok 
 *   E_FAIL else 
 *   return error code for C++ Implementations
 * @see CATIAHybridShapeFactory 
 */ 
 HRESULT put_ReferenceElement (in     CATIAReference   iRefElem);
 
};


// Interface name : CATIAHybridShapeNear
#pragma ID CATIAHybridShapeNear "DCE:8c89b282-64f5-0000-0280020e60000000"
#pragma DUAL CATIAHybridShapeNear

// VB object name : HybridShapeNear (Id used in Visual Basic)
#pragma ID HybridShapeNear "DCE:8c89b287-912a-0000-0280020e60000000"
#pragma ALIAS CATIAHybridShapeNear HybridShapeNear

#endif
