#ifndef CATIAHybridShapeAxisToAxis_IDL
#define CATIAHybridShapeAxisToAxis_IDL
/*IDLREP*/

// COPYRIGHT DASSAULT SYSTEMES 2000

/**
  * @CAA2Level L1
  * @CAA2Usage U3
  */


//=================================================================
//=================================================================
//           
// CATIAHybridShapeAxisToAxis:         
// Exposed interface for HybridShape axis to axis tranformation 
//           
//=================================================================
// Usage notes:
//
//=================================================================
// FCB ; 12-06-2001 ; Creation    
//=================================================================
#include "CATIAHybridShape.idl"
#include "CATIAReference.idl"

/**
 * Represents the hybrid shape axis to axis tranformation feature object.
 * <b>Role</b>: To access the data of the axis to axis tranformation shape feature object.
 * The data includes:
 * <ul>
 * <li> The element to be transformed </li>
 * <li> The reference axis system </li>
 * <li> The target axis system </li>
 * </ul>
 * <p>  LICENSING INFORMATION: Creation of volume result requires GSO License
 * <br> if GSO License is not granted , settting of Volume context has not effect 
 * <br> 
  * Use the CATIAHybridShapeFactory to create HybridShapeFeature object.
 * @see CATIAHybridShapeFactory
 */
//-----------------------------------------------------------------
interface CATIAHybridShapeAxisToAxis : CATIAHybridShape
{

 /**
 * Returns or sets the element to transform.
 * <dl>
 * <dt><b>Example</b>:
 * <dd>
 * This example retrieves in <code>Elem</code> the element to transform for the <code>AxisToAxis</code> hybrid shape feature.
 *<pre>
 * Dim Elem As Reference
 * Set Elem = AxisToAxis.<font color="red">ElemToTransform</font>
 *</pre>
 *</dl> 
 */
#pragma PROPERTY ElemToTransform 
    HRESULT get_ElemToTransform (out /*IDLRETVAL*/ CATIAReference oElem) ;
    HRESULT put_ElemToTransform (in                CATIAReference iElem)  ;




 /**
 * Returns or sets the reference axis.
 * <dl>
 * <dt><b>Example</b>:
 * <dd>
 * This example retrieves in <code>Ref</code> the reference axis for the <code>AxisToAxis</code> hybrid shape feature.
 *<pre>
 * Dim Ref As Reference
 * Set Ref = AxisToAxis.<font color="red">ReferenceAxis</font>
 *</pre>
 *</dl> 
 */ 
#pragma PROPERTY ReferenceAxis
    HRESULT get_ReferenceAxis(out /*IDLRETVAL*/ CATIAReference oAxis) ;
    HRESULT put_ReferenceAxis(in                CATIAReference iAxis) ;




 /**
 * Returns or sets the target axis.
 * <dl>
 * <dt><b>Example</b>:
 * <dd>
 * This example retrieves in <code>Ref</code> the target axis for the <code>AxisToAxis</code> hybrid shape feature.
 *<pre>
 * Dim Ref As Reference
 * Set Ref = AxisToAxis.<font color="red">ReferenceAxis</font>
 *</pre>
 *</dl> 
 */ 
#pragma PROPERTY TargetAxis
    HRESULT get_TargetAxis(out /*IDLRETVAL*/ CATIAReference oAxis) ;
    HRESULT put_TargetAxis(in                CATIAReference iAxis) ;

/**
 *  Returns or sets the volume result.
 * <br><b>Legal values</b>: <b>True</b> if the result of axis to axis transformation is required as volume
 * (option is effective only in case of volumes,requires GSO License)) and <b>False</b> if it is needed as surface .
 * @sample
 * This example sets that the result of
 * the <code>hybShpAxisToAxis</code> hybrid shape AxisToAxis is volume.
 * <pre>
 * hybShpAxisToAxis.<font color="red">VolumeResult</font> = True
 * </pre>
 */ 
#pragma PROPERTY VolumeResult
 HRESULT get_VolumeResult(out /*IDLRETVAL*/ boolean oType);
 HRESULT put_VolumeResult(in boolean iType);

/**
 *  Returns or sets the creation mode(creation or modification).
 * <br><b>Legal values</b>: <b>True</b> if the result is a creation feature 
 * and <b>False</b> if the result is a modification feature.
 * @sample
 * This example sets that the mode of
 * the <code>hybShpAxisToAxis</code> hybrid shape axis to axis to creation
 * <pre>
 * hybShpAxisToAxis.<font color="red">CreationMode</font> = True
 * </pre>
 */ 
#pragma PROPERTY CreationMode
 HRESULT get_CreationMode(out /*IDLRETVAL*/ boolean oCreation);
 HRESULT put_CreationMode(in boolean iCreation);
};


// Interface name : CATIAHybridShapeAxisToAxis
#pragma ID CATIAHybridShapeAxisToAxis "DCE:42ea9880-60a2-11d5-9f0900508b5fe60c"
#pragma DUAL CATIAHybridShapeAxisToAxis

// VB object name : HybridShapeAxisToAxis (Id used in Visual Basic)
#pragma ID HybridShapeAxisToAxis "DCE:9f6e3f90-60a2-11d5-9f0900508b5fe60c"
#pragma ALIAS CATIAHybridShapeAxisToAxis HybridShapeAxisToAxis

#endif
// CATIAHybridShapeAxisToAxis_IDL

