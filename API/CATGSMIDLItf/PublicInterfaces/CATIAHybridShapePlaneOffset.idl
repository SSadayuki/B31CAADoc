/**
  * @CAA2Level L1
  * @CAA2Usage U3
  */


//=================================================================
//=================================================================
//           
// CATIAHybridShapePlaneOffset:         
// Exposed interface for HybridShape PlaneOffset
//           
//=================================================================
// Usage notes:
//
//=================================================================
// Avril98 Creation
//=================================================================
#include "CATIAHybridShapePlane.idl"
#include "CATIAReference.idl"
#include "CATIALength.idl"

/**
 * Offset plane.
 * <b>Role</b>: Allows to access data of the plane feature created with
 * an offset to another plane.
 */

//-----------------------------------------------------------------
interface CATIAHybridShapePlaneOffset : CATIAHybridShapePlane
{
 //  ================
 //  == PROPERTIES ==
 //  ================

/**
 * Returns or sets the reference plane.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * @href CATIAPlanarFace.
 */ 
#pragma PROPERTY Plane
 HRESULT get_Plane ( out /*IDLRETVAL*/  CATIAReference   oPlane);
 HRESULT put_Plane ( in           CATIAReference   iPlane);

/**
 * Returns the offset value.
 */ 
#pragma PROPERTY Offset
 HRESULT get_Offset ( out /*IDLRETVAL*/  CATIALength   oX);

/**
 * Returns or sets the plane orientation.
 * <br><b>Role</b>: The orientation allows you to invert the plane from the reference plane.
 * <br><b>Legal values</b>:
 * the orientation is 1 if the plane orientation is not inverted, and -1 otherwise.
 */ 
#pragma PROPERTY Orientation
 HRESULT get_Orientation (out /*IDLRETVAL*/  long       oOrientation);
 HRESULT put_Orientation (in       long       iOrientation);
};

// Interface name : CATIAHybridShapePlaneOffset
#pragma ID CATIAHybridShapePlaneOffset "DCE:89d7662d-f4a3-0000-0280020e60000000"
#pragma DUAL CATIAHybridShapePlaneOffset

// VB object name : HybridShapePlaneOffset (Id used in Visual Basic)
#pragma ID HybridShapePlaneOffset "DCE:89d7692a-c8f6-0000-0280020e60000000"
#pragma ALIAS CATIAHybridShapePlaneOffset HybridShapePlaneOffset

#endif
