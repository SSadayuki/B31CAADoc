#include "CATIAHybridShapePlane.idl"
interface CATIAReference;

/**
 * Tangency plane.
 * <b>Role</b>: Allows to access data of the the plane feature tangent to a
 * surface at a given point.
 */

//-----------------------------------------------------------------
interface CATIAHybridShapePlaneTangent : CATIAHybridShapePlane
{
 //  ================
 //  == PROPERTIES ==
 //  ================
#pragma PROPERTY Surface





 /**
 * <b>Role</b>: Get the surface to which the plane is to be tangent.
 * @param oSurface
 *   reference surface.
 *   @see CATIAReference 
 * @return HRESULT 
 *   S_OK   if Ok 
 *   E_FAIL else 
 *   return error code for C++ Implementations
 * @see CATIAHybridShapeFactory 
 */ 
 HRESULT get_Surface ( out /*IDLRETVAL*/  CATIAReference   oSurface);





 /**
 * <b>Role</b>: Set the surface to which the plane is to be tangent.
 * @param iSurface
 *   reference surface.
 *   @see CATIAReference 
 * @return HRESULT 
 *   S_OK   if Ok 
 *   E_FAIL else 
 *   return error code for C++ Implementations
 * @see CATIAHybridShapeFactory 
 */ 
 HRESULT put_Surface ( in            CATIAReference   iSurface);

#pragma PROPERTY Point





 /**
 * <b>Role</b>: Get the tangency point.
 * @param oPoint
 *   tangency point.
 *   @see CATIAReference 
 * @return HRESULT 
 *   S_OK   if Ok 
 *   E_FAIL else 
 *   return error code for C++ Implementations
 * @see CATIAHybridShapeFactory 
 */ 
 HRESULT get_Point ( out /*IDLRETVAL*/  CATIAReference   oPoint);





 /**
 * <b>Role</b>: Set the tangency point.
 * @param iPoint
 *   tangency point.
 *   @see CATIAReference 
 * @return HRESULT 
 *   S_OK   if Ok 
 *   E_FAIL else 
 *   return error code for C++ Implementations
 * @see CATIAHybridShapeFactory 
 */ 
 HRESULT put_Point ( in           CATIAReference   iPoint);
};





// Interface name : CATIAHybridShapePlaneTangent
#pragma ID CATIAHybridShapePlaneTangent "DCE:89d76636-8fc0-0000-0280020e60000000"
#pragma DUAL CATIAHybridShapePlaneTangent

// VB object name : HybridShapePlaneTangent (Id used in Visual Basic)
#pragma ID HybridShapePlaneTangent "DCE:89d76934-5fc7-0000-0280020e60000000"
#pragma ALIAS CATIAHybridShapePlaneTangent HybridShapePlaneTangent


#endif


