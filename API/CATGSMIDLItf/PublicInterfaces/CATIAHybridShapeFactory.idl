 */ 
   HRESULT AddNewCurveSmooth  (in                CATIAReference   ipIACurve, 
         out /*IDLRETVAL*/ CATIAHybridShapeCurveSmooth     opIACurveSmooth);

 /**
 * Creates a new Translate within the current body. 
