/**
 * Creates a new circle with given center element and tangent curve. 
 * @param iCenterElem 
 *   Can be either curve or point.
 * @param iTangentCurve 
 *   Curve to which the circle will be tangent.
 * @param iSupport 
 *   support surface or plane.
 * @param iRadius 
 *   circle radius, valid only if center element is curve. Value specified is considered as radius. 
 *   To use this value as diameter, set DiameterMode using SetDiameterMode method
 * @param oCircle
 *   Created circle
 */ 
 
 HRESULT AddNewCircleCenterTangent(in CATIAReference iCenterElem,
         in CATIAReference iTangentCurve,
         in CATIAReference iSupport,
         in double         iRadius,
         out /*IDLRETVAL*/ CATIAHybridShapeCircleCenterTangent oCircle);

/**
 * Creates a circle from point and axis. 
 * @param iAxis
 *   Axis of plane in which circle is lying
 * @param iPoint 
 *   Point used for center computation. It will be the center if ProjectionMode
 *   is False. If ProjectionMode = True, this point will be projected on to axis/line
 * @param iValue 
 *   Value specified is considered as radius. To use this value as diameter,
 *   set DiameterMode property
 * @param iProjection 
 *   Sets Projection Mode. ProjectionMode = TRUE implies point will be projected on to axis/line,
 *   ProjectionMode = FALSE implies that point will be center of the circle. 
 * @param oCircle
 *   Created circle
 */ 
 
 HRESULT AddNewCircleCenterAxis(in CATIAReference iAxis,
         in CATIAReference iPoint,
		 in double         iValue,
		 in boolean        iProjection,
         out /*IDLRETVAL*/ CATIAHybridShapeCircleCenterAxis oCircle);

/**
 * Creates a circle from point and axis. 
 * @param iAxis
 *   Axis of plane in which circle is lying
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * @param iPoint 
 *   Point used for center computation. It will be the center if ProjectionMode
 *   is False. If ProjectionMode = True, this point will be projected on to axis/line
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * @param iValue 
 *   Value specified is considered as radius. To use this value as diameter,
 *   set DiameterMode property
 * @param iProjection 
 *   Sets Projection Mode. ProjectionMode = TRUE implies point will be projected on to axis/line,
 *   ProjectionMode = FALSE implies that point will be center of the circle. 
 * @param iStartAngle 
 *   start angle
 * @param iEndAngle 
 *   end angle
 * @param oCircle
 *   Created circle
 */ 
 
 HRESULT AddNewCircleCenterAxisWithAngles (in CATIAReference iAxis,
         in CATIAReference iPoint,
         in double         iValue,
		 in boolean        iProjection,
         in double         iStartAngle,
         in double         iEndAngle,
         out /*IDLRETVAL*/ CATIAHybridShapeCircleCenterAxis oCircle);

