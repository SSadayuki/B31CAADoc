 * @see CATIAHybridShapeTranslate 
 */ 
   HRESULT AddNewTranslate   (in                CATIAReference                iElement, 
                              in                CATIAHybridShapeDirection     iDirection, 
                              in                double                        iDistance, 
         out /*IDLRETVAL*/ CATIAHybridShapeTranslate     oTranslate);

 /**
 * Creates a new empty Translate within the current body.
 */
   HRESULT AddNewEmptyTranslate   (out /*IDLRETVAL*/ CATIAHybridShapeTranslate     oTranslate);

 /**
 * Creates a new Affinity within the current body. 
 * @param iElement 
 *   point, curve, surface or solid.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace, @href CATIATriDimFeatEdge, @href CATIABiDimFeatEdge and @href CATIAVertex.
 * @param iXRatio 
 *   Ratio of affinity in iX direction. 
 * @param iYRatio 
 *   Ratio of affinity in iY direction.
 * @param iZRatio 
 *   Ratio of affinity in iZ direction.  
 * @param oAffinity 
 *   Created affinity
 */ 
   HRESULT AddNewAffinity   (in                CATIAReference                iElement, 
                             in                double                        iXRatio, 
                             in                double                        iYRatio, 
                             in                double                        iZRatio, 
        out /*IDLRETVAL*/ CATIAHybridShapeAffinity      oAffinity);

 /**
 * Creates a new Split within the current body. 
 * @param iElement1 
 *   The feature to cut (curve or surface).
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace, @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iElement2 
 *   The cutting feature (point, curve, surface).
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace, @href CATIATriDimFeatEdge, @href CATIABiDimFeatEdge and @href CATIAVertex.
 * @param iOrientation 
 *   Manage the kept side of the feature to cut (value can be 1 or -1)
 * @param oSplit 
 *   Created split
 */ 
   HRESULT AddNewHybridSplit   (in              CATIAReference         iElement1, 
        in              CATIAReference         iElement2, 
        in              long                   iOrientation, 
        out /*IDLRETVAL*/ CATIAHybridShapeSplit      oSplit);

 /**
 * Creates a new Trim within the current body by cutting and joining two elements.
    * <br>You can trim a surface by a surface or a curve by a curve. 
 * @param iElement1 
 *   The feature to trim (curve or surface).
 * @param iOrientation1 
 *   Manage the kept side of iElement1  (value can be 1 or -1).
 * @param iElement2 
 *   The second feature to trim (curve or surface).
 * @param iOrientation2 
 *   Manage the kept side of iElement2  (value can be 1 or -1).
 * @param oTrim 
 *   Created trim.
 */ 
   HRESULT AddNewHybridTrim   ( in              CATIAReference    iElement1, 
        in              long                        iOrientation1, 
        in              CATIAReference              iElement2, 
        in              long                        iOrientation2, 
        out /*IDLRETVAL*/ CATIAHybridShapeTrim      oTrim);

/**
 * Creates a new Project within the current body. 
 * @param iElement 
 *   Element to project (point, curve).
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge, @href CATIABiDimFeatEdge and @href CATIAVertex.
 * @param iSupport 
 *   Curve or surface support for projection.  
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace, @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.  
 * @param oProjection 
 *   Created projection
 */ 
   HRESULT AddNewProject  (in                CATIAReference           iElement, 
                           in                CATIAReference           iSupport, 
         out /*IDLRETVAL*/ CATIAHybridShapeProject  oProjection);
 /**
 * Creates a new Corner within the current body.
 * <br> Create a corner curve between a point and a curve or 2 curves on a support surface. 
 * @param iElement1 
 *   First reference curve.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge, @href CATIABiDimFeatEdge and @href CATIAVertex.
 * @param iElement2 
 *   Second reference curve.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge, @href CATIABiDimFeatEdge and @href CATIAVertex.
 * @param iSupport 
 *   Support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iRadius 
 *   Radius of the corner.
 * @param iOrientation1 
 *   Manage the corner center position.
 *   Value can be 1 or -1 
 * @param iOrientation2 
 *   Manage the corner center position.
 *   Value can be 1 or -1     
 * @param iTrim 
 *   Value can be FALSE or TRUE<br>
 *   if TRUE the 2 curves are trimed and asembled with the corner.
 * @param oCorner 
 *   Created corner.
 */ 
   HRESULT AddNewCorner  (in              CATIAReference  iElement1, 
                          in              CATIAReference  iElement2, 
                          in              CATIAReference  iSupport, 
                          in              double          iRadius, 
                          in              long            iOrientation1, 
                          in              long            iOrientation2, 
                          in              boolean         iTrim, 
     out /*IDLRETVAL*/ CATIAHybridShapeCorner  oCorner);

 /**
 * Creates a new 3D Corner within the current body.
 * <br> Create a 3D corner curve between a point and a curve or 2 curves along a direction. 
 * @param iElement1 
 *   First reference curve.
 * @param iElement2 
 *   Second reference curve.
 * @param iDirection 
 *   Direction.
 * @param iRadius 
 *   Radius of the corner.
 * @param iOrientation1 
 *   Manage the corner center position.
 *   Value can be 1 or -1 
 * @param iOrientation2 
 *   Manage the corner center position.
 *   Value can be 1 or -1     
 * @param iTrim 
 *   Value can be FALSE or TRUE<br>
 *   if TRUE the 2 curves are trimed and asembled with the corner.
 * @param oCorner 
 *   Created corner.
 */ 
   HRESULT AddNew3DCorner  (in              CATIAReference  iElement1, 
							in              CATIAReference  iElement2, 
							in              CATIAHybridShapeDirection  iDirection, 
							in              double          iRadius, 
							in              long            iOrientation1, 
							in              long            iOrientation2, 
							in              boolean         iTrim, 
     out /*IDLRETVAL*/ CATIAHybridShapeCorner  oCorner);

 /**
 * Creates a new Extrapol (until an element) within the current body. 
 * @param iBoundary 
