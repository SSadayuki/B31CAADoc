 */ 
   HRESULT AddNewLoft (out /*IDLRETVAL*/ CATIAHybridShapeLoft       oExt);

 /**
 * Creates a new Join within the current body. 
 * @param iElement1 
 *   First element to join ( curve or surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
