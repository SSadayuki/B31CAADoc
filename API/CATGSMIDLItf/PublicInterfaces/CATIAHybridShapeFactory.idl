 // ===========================================================================
 //  Datums 
 // ===========================================================================
 /**
 * Creates datums from a multi-domain result feature, one datum is created by object domain. 
 * <br> Note; Available only for a shape design feature as input ( not for datum feature ).    
 * @param iElem 
 *  Reference element 
 * @param oArrayOfDatum 
 *  List of datum objects , one datum is created per omain 
 * <br> Level of availability = V5R14 
 * <dl>
 * <dt><b>Example</b>:
 * <dd>
 * This example converts a hybrid shape object in as much as datums that the original 
 * hybrid shape features contains of domain 
 * <pre>
 *  Dim HShape 
 *  Set reference   = part.CreateReferenceFromObject(hybridShapeObject)
 *  ' Convert to Datums 
 *  HShape = hybridShapeFactory.<font color="red">AddNewDatums</font> reference  
 *  Num =UBound(HShape)
 *  For i = 0 to Num  
 *        hybridBody1.AppendHybridShape HShape (i) 
 *  Next 
 *  part.InWorkObject = HShape(num) 
 *  part.Update 
 *  ' Delete original feature 
 *  hybridShapeFactory.DeleteObjectForDatum reference
 * </pre> 
 */
 HRESULT AddNewDatums(in CATIAReference       iElem, 
       	                            out /*IDLRETVAL*/    CATSafeArrayVariant oArrayOfDatum ) ;

 /**
 * Returns type of "geometrical" shape Design feature . 
 * @param iElem 
 *  Reference element  
 * @param oType  
 *   Type of feature 
 *   = 0 , Unknown 
 *   = 1 , Point 
 *   = 2 , Curve 
 *   = 3 , Line 
 *   = 4 , Circle 
 *   = 5 , Surface 
 *   = 6 , Plane 
 *   = 7 , Solid, Volume 
 * <br> Level of availability = V5R14 
 */
 HRESULT GetGeometricalFeatureType   ( in CATIAReference   iElem, 	out /*IDLRETVAL*/ short  oType );  		
 
 // ===========================================================================
 //  Shape Design Automation Tools 
 // ===========================================================================

/**
 * Set Visibility attribut for Shape Design Features.
 *   @param iElem 
 *      Element to show/NoShow 
 *   @param Show 
 *      = 0 NoShow , 1= Show
 */
 HRESULT GSMVisibility (in CATIAReference       iElem, in long  Show);

/**
 * Set display name for Shape Design Features. 
 *   @param iElem 
 *      Element to rename 
 *   @param Name 
 *      User name  
 */
 HRESULT ChangeFeatureName	(in CATIAReference       iElem, in CATBSTR Name);

/**
 * Creates a new Transfer within the current body. 
  * <br> Note: require DL1 license.
 * @param iElementToTransfer
 *	The element to transfer
 * @param iTypeOfTransfer
 *	The type of transfer
 * @param oExt 
 *   Created Transfer operation.
 */ 
 HRESULT AddNewTransfer (in CATIAReference			iElementToTransfer,
							in  long  iTypeOfTransfer,
							out /*IDLRETVAL*/ CATIAHybridShapeTransfer oExt);

 // ===========================================================================
 // Do not use internal DS Only
 // ===========================================================================

 /**
 * @nodoc 
 */
 HRESULT GSMGetObjectFromReference (in CATIAReference       iElem, out /*IDLRETVAL*/ CATIAHybridShape oObjet);

 /**
 * @nodoc 
 */
 HRESULT DuplicateGSMSpec (in CATIAReference       iRef,
         out /*IDLRETVAL*/ CATIAHybridShape  oDupSpec);

 /**
 * @nodoc 
 */
 HRESULT SetReferenceElemForMultiple (in CATIAReference       iSpec,
           in CATIAReference       iNewRef);

/**
 * Creates a new point on a curve with a reference point and from a distance along direction. 
 * @param iCrv 
 *   support curve.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iPt 
 *   reference point.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iLong 
 *   distance (length) to reference point
 * @param iOrientation 
 *   Orientation = TRUE means that distance is measured in the other orientation of the curve
 * @param iDirection 
 *   Direction = The distance at which point is created is measured in this direction.
 * @param oPoint 
 *   Created point
 */ 
   HRESULT  AddNewPointOnCurveWithReferenceAlongDirection(in CATIAReference iCrv,
					in CATIAReference iPt,
					in double iLong,
					in boolean iOrientation,
					in CATIAHybridShapeDirection iDirection,
					out /*IDLRETVAL*/ CATIAHybridShapePointOnCurve oPoint);
 /**
 * Creates a new point on a curve with a deafult origin point and from a distance along direction. 
 * @param iCrv 
 *   support curve.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iLong 
 *   distance to default origin point.(origin of acurrent axis system)
 * @param iOrientation 
 *   Orientation = TRUE means that distance is measured in the other orientation of
 *   the curve.
  * @param iDirection 
 *   Direction = The distance at which point is created is measured in this direction.
 * @param oPoint 
 *   Created point
 */ 
   HRESULT  AddNewPointOnCurveAlongDirection (in CATIAReference iCrv,
          in double iLong,
          in boolean iOrientation,
					in CATIAHybridShapeDirection iDirection,
					out /*IDLRETVAL*/ CATIAHybridShapePointOnCurve oPoint);

   /**
   * Creates a new MidSurface in Automatic Creation Mode Only. 
   * @param iSupport 
   *   support Body
   * @param iCreationMode 
   *   Creation Mode (Only Automatic Accepted)
   * @param iThreshold 
   *   Threshold Thickness
   * @return oMidSurface 
   *   Created MidSurface
   */ 

   HRESULT AddNewMidSurface (in CATIAReference iSupport,
	   in long iCreationMode,
	   in double iThreshold,
	   out /*IDLRETVAL*/ CATIAHybridShapeMidSurface oMidSurface);

   /**
   * Creates a new MidSurface in Automatic Creation Mode Only. 
   * @param iSupport 
   *   support Body
   * @param iCreationMode 
   *   Creation Mode (Only Automatic Accepted)
   * @param iThreshold 
   *   Threshold Thickness
   * @param iAutoThicknessThreshold
   *  Automatic Thickness Threshold
   * @return oMidSurface 
   *   Created MidSurface
   */ 

   HRESULT AddNewMidSurfaceWithAutoThreshold (in CATIAReference iSupport,
	   in long iCreationMode,
	   in double iThreshold,
	   in long iAutoThicknessThreshold,
	   out /*IDLRETVAL*/ CATIAHybridShapeMidSurface oMidSurface);

};

