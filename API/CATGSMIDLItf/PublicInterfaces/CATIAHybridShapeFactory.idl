 /**
 * @deprecated  V5R17 CATIAHybridShapeFactory#AddNewReflectLineWithType
 * Creates a new ReflectLine within the current body.
 * <br> Create a reflectline curve on a support surface along a direction with an angle. 
 * @param iSupport 
 *   Support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iAngle 
 *   Angle of the reflectline.
 * @param iOrientationSupport 
 *   Manage the angle used to compute the reflectline.
 *   Value can be 1 or -1 
 * @param iOrientationDirection 
 *   Manage the angle used to compute the reflectline.
 *   Value can be 1 or -1     
 * @param oReflectLine 
 *   Created reflectline.
 */ 
   HRESULT AddNewReflectLine  (in              CATIAReference             iSupport, 
                               in              CATIAHybridShapeDirection  iDir,
                               in              double                     iAngle, 
                               in              long                       iOrientationSupport, 
                               in              long                       iOrientationDirection, 
                               out /*IDLRETVAL*/ CATIAHybridShapeReflectLine  oReflectLine);

 /**
 * Creates a new ReflectLine within the current body.
 * <br> Create a reflectline curve on a support surface along a direction with an angle. 
 * @param iSupport 
 *   Support surface.
 * @param iAngle 
 *   Angle of the reflectline.
 * @param iOrientationSupport 
 *   Manage the angle used to compute the reflectline.
 *   Value can be 1 or -1 
 * @param iOrientationDirection 
 *   Manage the angle used to compute the reflectline.
 *   Value can be 1 or -1     
 * @param iType 
 *   Manage the type used to compute the reflectline.
 *   Value can be 0 or 1
 *   Returns or sets whether the reflectline curve is or should be created with the normal
 *   to the support or the tangent plane to the support.
 *   <br><b>Role</b>: The TypeSolution indicates whether the created reflectline curve
 *   is compute with the angle between the normale to the support and the direction 
 *   or with the angle between the tangent plane to the support and the direction..
 *   <br><b>Legal values</b>: 0 for the normal and 1 for the tangent plane.
 * @param oReflectLine 
 *   Created reflectline.
 */ 
   HRESULT AddNewReflectLineWithType  (in              CATIAReference             iSupport, 
                               in              CATIAHybridShapeDirection  iDir,
                               in              double                     iAngle, 
                               in              long                       iOrientationSupport, 
                               in              long                       iOrientationDirection, 
                               in              long                       iType, 
                               out /*IDLRETVAL*/ CATIAHybridShapeReflectLine  oReflectLine);

 /**
 * Creates a new conical ReflectLine within the current body.
 * <br> Create a conical reflectline curve on a support surface from an origin point with an angle. 
 * @param iSupport 
 *   Support surface.
 * @param iOrigin 
 *   Origin point.
 * @param iAngle 
 *   Angle of the reflectline.
 * @param iOrientationSupport 
 *   Manage the angle used to compute the reflectline.
 *   Value can be 1 or -1 
 * @param iType 
 *   Manage the type used to compute the reflectline.
 *   Value can be 0 or 1
 *   Returns or sets whether the reflectline curve is or should be created with the normal
 *   to the support or the tangent plane to the support.
 *   <br><b>Role</b>: The TypeSolution indicates whether the created reflectline curve
 *   is compute with the angle between the normale to the support and the direction 
 *   or with the angle between the tangent plane to the support and the direction..
 *   <br><b>Legal values</b>: 0 for the normal and 1 for the tangent plane.
 * @param oReflectLine 
 *   Created conical reflectline.
 */ 
  HRESULT AddNewConicalReflectLineWithType  (in              CATIAReference             iSupport, 
                               in              CATIAReference             iOrigin,
                               in              double                     iAngle, 
                               in              long                       iOrientationSupport, 
                               in              long                       iType, 
                               out /*IDLRETVAL*/ CATIAHybridShapeReflectLine  oReflectLine);

