       in                long                 Inverse,          
         out /*IDLRETVAL*/ CATIAHybridShapeInverse       oInv);

 /**
 * Creates a new Near within the current body. 
 * @param iMultiElement 
 *   Non connex element (point,curve,surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace, @href CATIATriDimFeatEdge, @href CATIABiDimFeatEdge and @href CATIAVertex.
 * @param iReferenceElement 
 *   Reference element<br>
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace, @href CATIATriDimFeatEdge, @href CATIABiDimFeatEdge and @href CATIAVertex.  
 * @param oNear 
 *   The result is the connex component that is the nearest from the reference element  
 */ 
   HRESULT AddNewNear        (in                CATIAReference                MultiElement, 
                              in                CATIAReference                ReferenceElement, 
         out /*IDLRETVAL*/ CATIAHybridShapeNear          oNear);

 /**
 * Creates a new Connect within the current body. 
 * @param iCurve1 
 *   First curve.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.  
 * @param iPoint1 
 *   First point (lying on the first curve)<br>
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.  
 * @param iOrient1 
 *   Orientation on the first curve  
 * @param iContinuity1 
 *   Continuity on first curve  
 * @param iTension1 
 *   Tension on first curve    
 * @param iCurve2 
 *   Second curve.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.  
 * @param iPoint2 
 *   Second point (lying on the second curve)<br>
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.  
 * @param iOrient2 
 *   Orientation on the second curve  
 * @param iContinuity2 
 *   Continuity on second curve  
 * @param iTension2 
 *   Tension on second curve  
 * @param iTrim 
 *   Trim the two curves with the connect  
 * @param oConnect 
 *   The connect object   
 */ 
   HRESULT AddNewConnect     (in             CATIAReference             iCurve1, 
                              in             CATIAReference             iPoint1, 
                              in             long                       iOrient1,
                              in             long                       iContinuity1,
                              in             double                     iTension1, 
                              in             CATIAReference             iCurve2, 
                              in             CATIAReference             iPoint2,
                              in             long                       iOrient2,
                              in             long                       iContinuity2,
                              in             double                     iTension2, 
                              in             boolean                    Trim,
         out /*IDLRETVAL*/ CATIAHybridShapeConnect       oConnect);

 /**
 * Creates a new CurvePar within the current body. 
 * @param iCurve 
 *   Reference curve.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.  
 * @param iSupport 
 *   Support on which the curve is lying on<br>
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.  
 * @param iDistance 
 *   Distance value  
 * @param iInvertDirection 
 *   Orientation
 * @param iGeodesic 
 *   Geodesic mode    
 * @param oCurvePar 
 *   Parallel curve  
 */ 
   HRESULT AddNewCurvePar    (in                CATIAReference                Curve, 
                              in                CATIAReference                Support, 
                              in                double                        Distance,
							  in                boolean                       InvertDirection,   
							  in                boolean                       Geodesic,   
         out /*IDLRETVAL*/ CATIAHybridShapeCurvePar     oCurvePar);

 /**
 * Creates a new CurveSmooth within the current body. 
