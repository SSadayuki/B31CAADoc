/**
 * Interface to create all kinds of HybridShape objects that may be needed in wireframe and surface design.
 * <br>Note:
 * <br>This interface concern GSD/GSO/DL1 feature creation via VB 
 * <br>      Use of the creation methods requires to have granted license configuration for feature creation
 * <br>      i.e:  
 * <br>      - Bump, Develop,WrapCurve,WrapSurface require GSO license. 
 * <br>      - Unfold,  Develop require DL1 license. 
 * <br>      - Other require GSD license. 
 * <br>Note2:
 * <br>For all methods creating datums AddNew*Datum,
 * <br>the object passed as parameter to create the datum has to be in the current container.
 * <br>Otherwise, an error occurs.
 */
interface CATIAHybridShapeFactory : CATIAFactory
{

/**
 * Creates a new spine within the current body. 
 * @param oExt 
 *   CATIAHybridShapeSpine created  
 */ 
   HRESULT AddNewSpine (out /*IDLRETVAL*/ CATIAHybridShapeSpine       oExt);

/**
 * Creates a new AxisLine within the current body. 
 * @param iElement
 *   Circle, Ellipse, Oblong, Sphere, Revolution surface. Axis is computed for this element
 * @param oAxisLine 
 *   Created axis line
 */ 
   HRESULT AddNewAxisLine (in CATIAReference iElement,
					       out /*IDLRETVAL*/ CATIAHybridShapeAxisLine oAxisLine);

/**
 * Creates a new law within the current body. 
 * @param iReference
 *   Reference line of the law.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIARectilinearTriDimFeatEdge and @href CATIARectilinearBiDimFeatEdge.
 * @param iDefinition 
 *   Definition curve of the law.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param oLaw
 *   The Law object if succeded  
 */ 
   HRESULT AddNewLawDistProj (in CATIAReference iReference,
							  in CATIAReference iDefinition,
					          out /*IDLRETVAL*/ CATIAHybridShapeLawDistProj oLaw);

/**
 * Creates a new blend surface within the current body. 
 * @param oBlend
 *   The Blend object if succeded  
 */ 
   HRESULT AddNewBlend (out /*IDLRETVAL*/ CATIAHybridShapeBlend  oBlend);


/**
 * Creates a new conic within the current body. 
    *   @param iSupport
    *      The conic support (always a plane).
    * <br>Sub-element(s) supported (see @href CATIABoundary object): 
    * see @href CATIAPlanarFace.
    *   @param iStartingPoint
    *      Starting Point.
    * <br>Sub-element(s) supported (see @href CATIABoundary object): 
    * see @href CATIAVertex.
    *   @param iEndPoint
    *      End Point<br>
    * <br>Sub-element(s) supported (see @href CATIABoundary object): 
    * see @href CATIAVertex.
 * @param oConic
 *   The Conic object if succeded  
 */ 
   HRESULT AddNewConic (in      CATIAReference   iSupport,
                        in      CATIAReference   iStartingPoint,
                        in      CATIAReference      iEndPoint,
      out /*IDLRETVAL*/ CATIAHybridShapeConic  oConic);



 /**
 * Creates a new Helix within the current body. 
    *   @param iAxis
    *      The helix axis (always a line).
    * <br>Sub-element(s) supported (see @href CATIABoundary object): 
    * see @href CATIARectilinearTriDimFeatEdge and @href CATIARectilinearBiDimFeatEdge.
    *   @param iInvertAxis
    *   @param iStartingPoint
    *      Starting Point.
    * <br>Sub-element(s) supported (see @href CATIABoundary object): 
    * see @href CATIAVertex.
    *   @param iPitch
    *      Pitch.
    *   @param iHeight
    *      Helix height.
    *   @param iClockwiseRevolution
    *      Revolutions are clockwise if TRUE, counterclockwise if FALSE.
    *   @param iStartingAngle
    *      Starting angle from starting point measured on the helix itself.
    *      If no starting angle is wanted, set it to 0.0.
    *   @param iTaperAngle
    *      0 &lt;= Taper Angle &lt; Pi/2
    *      If no taper angle is wanted, set it to 0.0 (constant helix radius).
    *   @param iTaperOutward
    *      Helix radius increases if TRUE, decreases if FALSE.
 * @param oHelix
 *   The Helix object if succeded  
 */ 
   HRESULT AddNewHelix (in      CATIAReference   iAxis,
                        in      boolean     iInvertAxis,
                        in      CATIAReference   iStartingPoint,
                        in      double     iPitch,
                        in      double     iHeight,
                        in      boolean     iClockwiseRevolution,
                        in      double     iStartingAngle,
                        in                double                 iTaperAngle,
                        in                boolean                iTaperOutward,
      out /*IDLRETVAL*/ CATIAHybridShapeHelix  oHelix);
                                        


 /**
 * Creates a new Combine within the current body. 
 * By default, the combine direction is the normal of each curve. If you want to change
 * see CATIAHybridShapeCombine interfaces.
 * @param iFirstCurve
 *   First curve to combine<br>
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.  
 * @param iSecondCurve 
 *   Second curve to combine<br>
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.  
 * @param iNearestSolution 
 *   If more than one solution, to choose the nearest solution of the first curve  
 * @param oCombine
 *   The combine object if succeded  
 */ 
   HRESULT AddNewCombine  (in                CATIAReference              iFirstCurve, 
                           in                CATIAReference              iSecondCurve, 
                           in                long       iNearestSolutions, 
                  out /*IDLRETVAL*/ CATIAHybridShapeCombine  oCombine);


 /**
 * Creates a new Extremum within the current body. 
 * @param iObjet 
 *   Element onto extremum is computed<br>
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge, @href CATIABiDimFeatEdge and @href CATIAFace.
 * @param iDir 
 *   Extremum direction
 * @param iMinMax 
        *                        Maximum (GSMMax) or Minimum (GSMMin)
 * @param oExt 
 *   The extremum object if succeded  
 */ 
 HRESULT AddNewExtremum (in CATIAReference        iObjet,
     in CATIAHybridShapeDirection     iDir,
     in long                          iMinMax,
     out /*IDLRETVAL*/ CATIAHybridShapeExtremum    oExt);

 /**
 * Creates a new Extremum Polar within the current body. 
 * @param iType 
 *   Type of extremum polar 0-Min Radius 1-Max Radius 2- Min Angle 3- Maximum Angle
 * @param ipIAContour 
 *   Extremum Polar Contour. It should be non convex
 * @param opIAExtPolar 
 *   The extremum polar object if succeded  
 */ 
 HRESULT AddNewExtremumPolar (in short              iType,
	 in	CATIAReference				  ipIAContour,
	 out /*IDLRETVAL*/ CATIAHybridShapeExtremumPolar  opIAExtPolar);

 /**
 * Creates a new Circle passing through 2 points with a radius within the current body. 
 * @param iPoint1 
 *   first passing point.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iPoint2 
 *   second passing point.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iSupport 
 *   support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iGeodesic 
 *   Puts the circle on the surface.
 * @param iRadius 
 *   Value specified is considered as radius. To use this value as diameter,
 *   set DiameterMode using SetDiameterMode method
 * @param iOri 
 *   circle orientation.
 *   Defines the side where circle is computed using the normal direction of line between the 2 passing points.
 * @param oCircle
 *   The Circle object if succeded  
 */ 
 HRESULT AddNewCircle2PointsRad (in CATIAReference iPoint1,
     in CATIAReference iPoint2,
     in CATIAReference iSupport,
     in boolean        iGeodesic,
     in double         iRadius,
     in long           iOri,
     out /*IDLRETVAL*/ CATIAHybridShapeCircle2PointsRad oCircle);


 /**
 * Creates a new a sphere bitangent fillet between two skins.
 * @param iElement1 
 *   First support of fillet. 
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace. 
 * @param iElement2 
 *   Second support of fillet.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iRadius 
 *   Radius of the fillet.
 * @param iOrientation1 
 *   Manage the fillet center position.
 * @param iOrientation2 
 *   Manage the fillet center position. 
 * @param iSupportsTrimMode 
 *   The 2 supports can be trimmed and assembled with the fillet.
 *   Value can be 0 (No trim ) or 1 (Trim)
 * @param iRibbonRelimitationMode 
 *   Manage the relimition of fillet extremities.
 *   Value can be : 0 (Smooth), 1 (Straight), 2 (Maximum) or 3 (Minimum)
 * @param oFillet
 *   Created fillet.
 */ 
   HRESULT AddNewFilletBiTangent ( in              CATIAReference  iElement1,
                          in              CATIAReference  iElement2,
                          in              double          iRadius,
                          in              long            iOrientation1,
                          in              long            iOrientation2,
                          in              long            iSupportsTrimMode,
						  in              long            iRibbonRelimitationMode,
						  out /*IDLRETVAL*/ CATIAHybridShapeFilletBiTangent  oFillet);

 /**
 * Creates a new a tritangent fillet between three skins.
 * @param iElement1 
 *   First support of fillet. 
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace. 
 * @param iElement2 
 *   Second support of fillet.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iRemoveElem 
 *   Support to remove of fillet.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iOrientation1 
 *   Manage the fillet center position.
 * @param iOrientation2 
 *   Manage the fillet center position. 
 * @param iRemoveOrientation 
 *   Manage the fillet center position. 
 * @param iSupportsTrimMode 
 *   The 2 supports can be trimmed and assembled with the fillet.
 *   Value can be 0 (No trim ) or 1 (Trim)
 * @param iRibbonRelimitationMode 
 *   Manage the relimition of fillet extremities.
 *   Value can be : 0 (Smooth), 1 (Straight), 2 (Maximum) or 3 (Minimum)
 * @param oFillet
 *   Created fillet.
 */ 
   HRESULT AddNewFilletTriTangent ( in              CATIAReference  iElement1,
                          in              CATIAReference  iElement2,
                          in              CATIAReference  iRemoveElem,
                          in              long            iOrientation1,
                          in              long            iOrientation2,
						  in              long            iRemoveOrientation,
                          in              long            iSupportsTrimMode,
						  in              long            iRibbonRelimitationMode,
						  out /*IDLRETVAL*/ CATIAHybridShapeFilletTriTangent  oFillet);

 /**
 * Creates a new circle passing through 3 points within the current body. 
 * @param iPoint1 
 *   first passing point.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iPoint2 
 *   second passing point.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iPoint3 
 *   third passing point.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param oCircle
 *   Created circle
 */ 
 HRESULT AddNewCircle3Points    (in CATIAReference iPoint1,
     in CATIAReference iPoint2,
     in CATIAReference iPoint3,
     out /*IDLRETVAL*/ CATIAHybridShapeCircle3Points oCircle);

 /**
 * Creates a new circle tangent to 2 curves and passing through one point within the current body. 
 * @param iCurve1 
 *   first curve to which the circle will be tangent.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iCurve2 
 *   second curve to which the circle will be tangent.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iPoint 
 *   passing point. This point must lie on second curve.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iSupport 
 *   support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iOri1 
 *   first curve orientation for circle computation.
 * @param iOri2 
 *   second curve orientation for circle computation.
 * @param oCircle
 *   Created circle
 */ 
 HRESULT AddNewCircleBitangentPoint (in CATIAReference iCurve1,
         in CATIAReference iCurve2,
         in CATIAReference iPoint,
         in CATIAReference iSupport,
         in long           iOri1,
         in long           iOri2,
            out /*IDLRETVAL*/ CATIAHybridShapeCircleBitangentPoint oCircle);
 /**
 * Creates a new circle tangent to 2 curves and with a radius within the current body. 
 * @param iCurve1 
 *   first curve to which the circle will be tangent.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iCurve2 
 *   second curve to which the circle will be tangent.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iSupport 
 *   support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iRadius 
 *   Value specified is considered as radius. To use this value as diameter,
 *   set DiameterMode using SetDiameterMode method
 * @param iOri1 
 *   first curve orientation for circle computation.
 * @param iOri2 
 *   second curve orientation for circle computation.
 * @param oCircle
 *   Created circle
 */ 
 HRESULT AddNewCircleBitangentRadius(in CATIAReference iCurve1,
         in CATIAReference iCurve2,
         in CATIAReference iSupport,
         in double         iRadius,
         in long           iOri1,
         in long           iOri2,
         out /*IDLRETVAL*/ CATIAHybridShapeCircleBitangentRadius oCircle);

 /**
 * Creates a new circle defined by its center, a passing point and angles within the current body. 
 * @param iCenter 
 *   circle center.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iCrossingPoint 
 *   passing point.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iSupport 
 *   support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iGeodesic 
 *   Puts the circle on the surface.
 * @param iStartAngle 
 *   start angle
 * @param iEndAngle 
 *   end angle
 * @param oCircle
 *   Created circle
 */ 
 HRESULT AddNewCircleCtrPtWithAngles (in CATIAReference iCenter,
         in CATIAReference iCrossingPoint,
         in CATIAReference iSupport,
         in boolean        iGeodesic,
         in double         iStartAngle,
         in double         iEndAngle,
         out /*IDLRETVAL*/ CATIAHybridShapeCircleCtrPt oCircle);

 /**
 * Creates a new whole circle defined by its center, a passing point within the current body. 
 * @param iCenter 
 *   circle center.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iCrossingPoint 
 *   passing point.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iSupport 
 *   support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iGeodesic 
 *   Puts the circle on the surface.
 * @param oCircle
 *   CreatedCircle
 */ 
 HRESULT AddNewCircleCtrPt (in CATIAReference iCenter,
         in CATIAReference iCrossingPoint,
         in CATIAReference iSupport,
         in boolean        iGeodesic,
         out /*IDLRETVAL*/ CATIAHybridShapeCircleCtrPt oCircle);
 /**
 * Creates a new circle defined by its center, a radius and angles within the current body. 
 * @param iCenter 
 *   circle center.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iSupport 
 *   support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iGeodesic 
 *   Puts the circle on the surface.
 * @param iRadius 
 *   Value specified is considered as radius. To use this value as diameter,
 *   set DiameterMode using SetDiameterMode method
 * @param iStartAngle 
 *   start angle
 * @param iEndAngle 
 *   end angle
 * @param oCircle
 *   Created circle
 */ 
 HRESULT AddNewCircleCtrRadWithAngles (in CATIAReference iCenter,
         in CATIAReference iSupport,
         in boolean        iGeodesic,
         in double         iRadius,
         in double         iStartAngle,
         in double         iEndAngle,
         out /*IDLRETVAL*/ CATIAHybridShapeCircleCtrRad oCircle);

 /**
 * Creates a new whole circle defined by its center and a radius within the current body. 
 * @param iCenter 
 *   circle center.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param iSupport 
 *   support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iGeodesic 
 *   Puts the circle on the surface.
 * @param iRadius 
 *   Value specified is considered as radius. To use this value as diameter,
 *   set DiameterMode using SetDiameterMode method
 * @param oCircle
 *   Created circle
 */ 
 HRESULT AddNewCircleCtrRad         (in CATIAReference iCenter,
         in CATIAReference iSupport,
         in boolean        iGeodesic,
         in double         iRadius,
         out /*IDLRETVAL*/ CATIAHybridShapeCircleCtrRad oCircle);
 /**
 * Creates a new tritangent circle within the current body. 
 * @param iCurve1 
 *   first curve to which the circle will be tangent.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iCurve2 
 *   second curve to which the circle will be tangent.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iCurve3 
 *   third curve to which the circle will be tangent.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIATriDimFeatEdge and @href CATIABiDimFeatEdge.
 * @param iSupport 
 *   support surface.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iOri1 
 *   first curve orientation for circle computation.
 * @param iOri2 
 *   second curve orientation for circle computation.
 * @param iOri3 
 *   third curve orientation for circle computation.
 * @param oCircle
 *   Created circle
 */ 
 HRESULT AddNewCircleTritangent     (in CATIAReference iCurve1,
         in CATIAReference iCurve2,
         in CATIAReference iCurve3,
         in CATIAReference iSupport,
         in long           iOri1,
         in long           iOri2,
         in long           iOri3,
          out /*IDLRETVAL*/ CATIAHybridShapeCircleTritangent oCircle);
 /**
 * Creates a new Develop within the current body. 
