   HRESULT AddNewSpline (out /*IDLRETVAL*/ CATIAHybridShapeSpline      oSpline);

 /**
 * Creates a new Spiral within the current body. 
    *   @param iType 
    *      Spiral is defined by AngleRadius, AnglePitch or PitchRadius.
    *   @param iSupport
    *      Spiral planar support.
    *   @param iCenterPoint
    *      Center point.
    *   @param iAxis
    *      Axis.
    *   @param iStartingRadius
    *      Defines the starting point: distance from the center point on the axis.
    *   @param iClockwiseRevolution
    *      Revolutions are clockwise if TRUE, counterclockwise if FALSE.
 * @param oSpiral
 *   The Spiral object if succeded  
 */ 
   HRESULT AddNewSpiral	(in		long								iType,
						 in		CATIAReference						iSupport,
						 in		CATIAReference						iCenterPoint,
						 in		CATIAHybridShapeDirection			iAxis,
						 in		double								iStartingRadius,	
						 in     boolean								iClockwiseRevolution,
						 out /*IDLRETVAL*/ CATIAHybridShapeSpiral	oSpiral);


  /**
 * Creates a new Boundary within the current body. 
 * @param iInitialElement 
 *   the element used to initialise the propagation around the surface <br>
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIABiDimFeatEdge.
 * @param iSupport 
 *   the surface used to compute the boundary around it<br>
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAFace.
 * @param iTypedePropagation
 *   Propagation type the values are:
 *     0  for Boundary for all edges
 *     1  for Boundary propagation for edges on connexe point
 *     2  for Boundary propagation for edges  tangent at point  breaks
 *     3  for Boundary not propagation from the current edge
 * @param oBoundary 
 *   The computed element
 */ 
   HRESULT AddNewBoundary (in CATIAReference iInitialElement,
      in CATIAReference iSupport,
      in long iTypedePropagation,
      out /*IDLRETVAL*/ CATIAHybridShapeBoundary oBoundary);

 /**
 * Creates a Boundary within the current body. 
 * @param iSurface 
 *   the feature on which all the boundaries will be computed  
 * @param oBoundary 
 *   the whole boundary of the Surface given in first parameter 
 */ 
   HRESULT AddNewBoundaryOfSurface (in CATIAReference Surface,
      out /*IDLRETVAL*/ CATIAHybridShapeBoundary oBoundary);
   
 /**
 * Creates a new point defined by its cartesian coordinates within the current body. 
 * @param iX 
        *                       X coordinate for the point
 * @param iY 
        *                       Y coordinate for the point
 * @param iZ 
        *                       Z coordinate for the point
 * @param oPoint 
 *   Created point
 */ 
   HRESULT AddNewPointCoord (in double iX,
        in double iY,
        in double iZ,
        out /*IDLRETVAL*/ CATIAHybridShapePointCoord oPoint);

 /**
 * Creates a new point defined its the cartesian coordinates regarding a reference point. 
 * @param iX 
        *                       X coordinate for the point
 * @param iY 
        *                       Y coordinate for the point
 * @param iZ 
        *                       Z coordinate for the point
 * @param iPt
		*						Reference point.
 * <br>Sub-element(s) supported (see @href CATIABoundary object): 
 * see @href CATIAVertex.
 * @param oPoint 
 *   Created point
 */ 
   HRESULT AddNewPointCoordWithReference (in double iX,
        in double iY,
        in double iZ,
		in CATIAReference iPt,
        out /*IDLRETVAL*/ CATIAHybridShapePointCoord oPoint);

 /**
 * Creates a new PointBetween within the current body. 
 * @param iPoint1
 *   Reference point to compute the barycenter.
