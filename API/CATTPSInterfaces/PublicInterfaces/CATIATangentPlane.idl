#include "CATIABase.idl"

/**
 * Interface for accessing Tangent Plane modifier on a TPS.
 */
interface CATIATangentPlane : CATIABase 
{
    /**
     * Retrieves Tangent Plane modifier.
     */
  #pragma PROPERTY Modifier
   HRESULT get_Modifier (inout /*IDLRETVAL*/ CATBSTR oModifier);
   HRESULT put_Modifier (in CATBSTR iModifier);
};

// Interface name : CATIATangentPlane
#pragma ID CATIATangentPlane "DCE:a33f6be6-260d-11d6-be890002b341dd3a"
#pragma DUAL CATIATangentPlane

// VB object name : TangentPlane (Id used in Visual Basic)
#pragma ID TangentPlane "DCE:a33f6be7-260d-11d6-be890002b341dd3a"
#pragma ALIAS CATIATangentPlane TangentPlane

#endif
