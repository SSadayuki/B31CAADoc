/**
* A ManufacturingSetup 3 for a Manufacturing Document.
*/
interface CATIAManufacturingSetup3 : CATIAManufacturingActivity
{

	/**
	* Add Fixture to part operation
	* @param iGeometry
	*   Geometry to assign
	* @param iProduct
	*   Product containing the geometry to assign.
	* @param iPosition
	*   Position of the geometry in the list (0 to append at the end of the list). 
	*/
	HRESULT AddFixture(in CATIABase iGeometry, in CATIABase iProduct, in short iPosition);

};


