OS = SunOS
LOCAL_CCFLAGS = -DXML_USE_ICONV_TRANSCODER -DXML_USE_V5_MSGLOADER -DAPP_NO_THREADS -DNATIVE_EXCEPTION -instances=static


OS = HP-UX
LOCAL_CCFLAGS = -DNATIVE_EXCEPTION -DXML_USE_ICONV_TRANSCODER -DXML_USE_V5_MSGLOADER -DAPP_NO_THREADS
LOCAL_POST_CCFLAGS = +inst_all

