/**
* Interface representing 3D state position.
*
* <br><b>Role</b>: A component that implements
* DNBIA3DStatePosition represents 3D state position object.
* This interface is used to set position, synchronize position,
* and set reference object for the 3D state position.
* <p>
*
Sample code to use the interface

Sub CATMain()
    Dim procDoc As ProcessDocument
    Set procDoc = DELMIA.ActiveDocument

    Dim positionMgt As DNB3DStatePositionManagement
    Set positionMgt = procDoc.DNB3DStatePositionManagement

    Dim listPositions as DNB3DStatePositions
    Set listPositions = positionMgt.GetAllPositions
    
	MySize = listPositions.Count
		
	For Index = 1 to MySize
		Dim currentPosition As DNB3DStatePosition
		Set currentPosition = listPositions.Item(Index)		
	Next

End Sub
*/
interface DNBIA3DStatePosition : CATIABase 
{
    /** 
     *  Sets position to the supplied transformation
     *  @param iTransformation
     *    The math transformation to be set to the position object.
     */
    HRESULT SetPosition( in CATSafeArrayVariant iTransformation );

    /** 
     *  Sets position to that of the supplied reference object
     *  @param iReferenceObject
     *    The reference object whose position to be set to this position object.
     */
    HRESULT SynchronizePositionWithReference( in CATBaseDispatch iReferenceObject );

    /** 
     *  Sets the reference object
     *  @param iReferenceObject
     *    The reference to be set to this position object.
     */
    HRESULT SetReference( in CATBaseDispatch iReferenceObject );

    /** 
     *  Sets the parent object
     *  @param iParentObject
     *    The parent to be set to this position object.
     */
    HRESULT SetParent( in CATBaseDispatch iParentObject );

    /** 
     *  Gets position to the supplied transformation
     *  @param oTransformation
     *    The math transformation to be retrieved from the position object.
     */
    HRESULT GetPosition( inout CATSafeArrayVariant oTransformation );

    /** 
     *  Gets the reference object
     *  @param oReferenceObject
     *    The reference to be retrieved from this position object.
     */
    HRESULT GetReference( out CATBaseDispatch oReferenceObject );

    /** 
     *  Gets the parent object
     *  @param oParentObject
     *    The parent to be retrieved from this position object.
     */
    HRESULT GetParent( out CATBaseDispatch oParentObject );

    /** 
     *  Sets position according to stored transformation and/or
     *  reference object where applicable
     */
    HRESULT SynchronizePosition( );

};

