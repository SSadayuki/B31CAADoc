#ifndef CATIASfmProfile_IDL
#define CATIASfmProfile_IDL
/*IDLREP*/

/**
* @CAA2Level L1
* @CAA2Usage U3
*/

#include "CATIASfmObject.idl"
#include "CATSafeArray.idl"
#include "CATIAReference.idl"
#include "CATIAReferences.idl"
#include "CATIASfmEndcut.idl"
#include "CATIASfmSlots.idl"

/**
 * Interface to manage the structure frame modeling member object
 * <b>Role</b>:  Allows accessing and setting of member's data.
 * @see CATIASfmFactory
 */
interface CATIASfmProfile : CATIASfmObject
{
  /**
  * Returns or sets the member's section name.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>Name</code> the name of section user by the <code>SfmProfile</code> feature.
  * <pre>
  * Dim Name As String
  * Set Name = SfmProfile.<font color="red">SectionName</font>
  * </pre>
  * </dl> 
  */ 
  #pragma PROPERTY SectionName
  HRESULT get_SectionName(inout  /*IDLRETVAL*/ CATBSTR oName);
  HRESULT put_SectionName(in CATBSTR iName);

  /**
  * Returns the member's support.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>Support</code> the support of the <code>SfmProfile</code> feature.
  * <pre>
  * Dim Support As Reference
  * Set Support = SfmProfile.<font color="red">Support</font>
  * </pre>
  * </dl> 
  */ 
  #pragma PROPERTY Support
  HRESULT get_Support(out /*IDLRETVAL*/ CATIAReference oSupport);

  /**
  * Returns or sets the member's anchor point.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>AnchorPointName</code> the anchor point name of the <code>SfmProfile</code> feature.
  * <pre>
  * Dim AnchorPointName As String
  * Set AnchorPointName = SfmProfile.<font color="red">AnchorPoint</font>
  * </pre>
  * </dl> 
  */ 
  #pragma PROPERTY AnchorPoint
  HRESULT get_AnchorPoint(inout  /*IDLRETVAL*/ CATBSTR oAnchorPoint);
  HRESULT put_AnchorPoint(in CATBSTR iAnchorPoint);

  /**
  * Compute the member's result.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example builds the result of the <code>SfmProfile</code> feature.
  * <pre>
  * SfmProfile.<font color="red">Run</font>
  * </pre>
  * </dl> 
  */ 
  HRESULT Run();

  /**
  * Retrieves the coordinates of the member's start extremity.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>StartExtr</code> the start extremity coordinates of the <code>SfmProfile</code> feature.
  * <pre>
  * SfmProfile.<font color="red">GetStartCoord</font> StartExtr
  * </pre>
  * </dl> 
  */ 
  HRESULT GetStartCoord(inout CATSafeArrayVariant oCoord);

  /**
  * Retrieves the coordinates of the member's end extremity.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>EndExtr</code> the end extremity coordinates of the <code>SfmProfile</code> feature.
  * <pre>
  * SfmProfile.<font color="red">GetEndCoord</font> EndExtr
  * </pre>
  * </dl> 
  */ 
  HRESULT GetEndCoord(inout CATSafeArrayVariant oCoord);

  /**
  * Retrieves the axis system of the section at a given location on the member's support.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>Origin</code>, <code>Vector1</code>, <code>Vector2</code>, <code>Vector3</code> the section axis at the start extremity of the <code>SfmProfile</code> feature.
  * <pre>
  * Dim Origin, Vector1, Vector2, Vector3 As 
  * SfmProfile.<font color="red">GetSectionAxis</font> 0., Origin, Vector1, Vector2, Vector3
  * </pre>
  * </dl> 
  */ 
  HRESULT GetSectionAxis(in double iAbside, inout CATSafeArrayVariant iOrigin, inout CATSafeArrayVariant ioVector1, inout CATSafeArrayVariant ioVector2, inout CATSafeArrayVariant ioVector3);
  /**
  * Creates Endcut on a SuperProfile.Use the method to create as well as edit the endcut.
  * @param iExtremityIndex [in]
  *     The extremity on which endcut is to be applied(1-Start,2-End).
  * @param iEndcutType [in]
  *   The type of Endcut(Snipe,Trim,Weld).
  * @param iEndcutName [in]
  *   Name of the Endcut.
  * @param iListContext [in]
  *   Context inputs for contextual endcuts or cutbacks.Not required for Custom.
  * @param iListParameters [in]
  *   The list of Parameters.
  * @param oSfmProfileEndCut [out]
  *   The created Endcut.
  * @return
  * <code>S_OK</code> if everything ran ok
  * <dl>
  * <dt><b>Example:<b>
  * <dd>
  * This Example creates a new contextual endcut on Stiifener Start extremity.
  * <pre>
  * ' First read the specifications required for endcut
  * Dim FactoryObj As SfmOperationFactory
  * Set FactoryObj = PartObj.GetCustomerFactory("SfmOperationFactory")
  * Dim EndCutManagerObj As SfmEndcutManager
  * Set EndCutManagerObj = FactoryObj.GetEndcutManager
  * Dim ListOfContextNames, ListOfUDFParamNames As Variant
  * Dim ListOfUDFParameters As SfmConnectionParameters
  * EndCutManagerObj.GetEndcutSpecifications "Tee", "Snipe", "T-CTX-PLATE", ListOfContextNames, ListOfUDFParameters, ListOfUDFParamNames
  * ' Read the Name of Context
  * Dim SizeOfContextNames As Long
  * SizeOfContext = UBound(ListOfContextNames)
  * Dim ContextName As String
  * For i = 0 To SizeOfContext  
  *  ContextName = ListOfContextNames(i)
  * Next
  * ' Read and Set the Parameter Values
  * Dim SizeOfUDFParams As Long
  * SizeOfUDFParams = ListOfUDFParameters.Count
  * Dim UDFParam As Parameter
  * For i = 1 To SizeOfUDFParams  
  *  Set UDFParam = ListOfUDFParameters.Item(i)
  *  Dim UDFParamName,UDFParamValue As String
  *  UDFParamName = ListOfUDFParamNames(j - 1)
  *  UDFParamValue = UDFParam.ValueAsString
  * 'Redefine Param Value
  *  If (UDFParamName = "Snipe Radius") Then
  *    UDFParam.ValuateFromString ("52mm")
  *  End If
  * Next
  * ' Define the Context
  * Dim FactoryRef As SfmFunctionFactory
  * Set FactoryRef = PartObj.GetCustomerFactory("SfmFunctionFactory")
  * Dim ListOfContexts As SfmReferences
  * Set ListOfContexts = FactoryRef.SfmReferences
  * Dim Limit As Reference
  * Set Limit = PartObj.CreateReferenceFromObject(SfmSuperPlateObj)
  * ListOfContexts.Add Limit
  * ' Create the Endcut
  * Dim EndCutObj As SfmEndcut
  * Set EndCutObj = SfmStiffenerObj.<font color="red">AddEndcut(1, "Snipe", "T-CTX-PLATE", ListOfContexts, ListOfUDFParameters)</font>
  * ' For Non Conetxtual Endcuts pass Nothing for iListContext
  * Set EndCutObj = SfmStiffenerObj.<font color="red">AddEndcut(1, "Snipe", "Web_Snipe_Radius", Nothing, ListOfUDFParameters)</font>
  * </pre>
  * </dl> 
  */
  HRESULT AddEndcut (in long  iExtremityIndex ,in CATBSTR iEndcutType , in CATBSTR iEndcutName , 
                     in CATIASfmReferences iListContext, in  CATIASfmConnectionParameters iListParameters,
                     out /*IDLRETVAL*/CATIASfmEndcut oSfmProfileEndCut ); 
  /**
  * Retrieves Existing Endcut on Profile.
  * @param iExtremityIndex [in]
  *      Extremity of Profile(1-Start,2-End).
  * @param oSfmEndcut [out]
  *      Retrieved Endcut.
  * @return
  * <code>S_OK</code> if everything ran ok
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example gets the Existing Endcut.
  * <pre>
  * Dim EndCutObj As SfmEndcut
  * Set EndCutObj = ProfileObj.<font color="red">GetEndcut(1)</font>
  * </pre>
  * </dl> 
  */ 
  HRESULT GetEndcut(in long  iExtremityIndex, out /*IDLRETVAL*/CATIASfmEndcut oSfmEndcut);
   /**
  * Removes Existing Endcut on Profile.
  * @param iExtremityIndex [in]
  *      Extremity of Profile(1-Start,2-End).
  * @return
  * <code>S_OK</code> if everything ran ok
  * <dl>
  * <dt>Example</dt>:
  * <dd>
  * This example removes the Existing Endcut.
  * <pre>
  * Dim EndCutObj As SfmEndcut
  * Set EndCutObj = ProfileObj.<font color="red">RemoveEndcut(1)</font>
  * </pre>
  * </dl> 
  */ 

  HRESULT RemoveEndcut( in long iExtremityIndex);  
  /**
  * Retrieves Slots on Profile.
  * @param oSfmSlots [out]
  *      Slots.
  * @return
  * <code>S_OK</code> if everything ran ok
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example gets the Slots.
  * <pre>
  * Dim SlotsonProfile As SfmSlots
  * Set SlotsonProfile = ProfileObj.<font color="red">GetSlotsOnProfile</font>
  * </pre>
  * </dl> 
  */ 
  HRESULT GetSlotsOnProfile(out /*IDLRETVAL*/CATIASfmSlots oSfmSlots);
  /**
  * Returns the limit at an Extremity of a Profile.
  * @param iExtremityIndex [in]
  *   Extremity of Profile(1-Start,2-End).
  * @param oLimit [out]
  *      Existing Limit.
  * @return
  * <code>S_OK</code> if everything ran ok.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves the Start Limit of a Stiffener.
  * <pre>
  * Dim ProfileLimit As Reference
  * Set ProfileLimit = SuperStiffenerObj.<font color="red">GetProfileLimit(1)</font>
  * </pre>
  * </dl> 
  */
  HRESULT GetProfileLimit(in long iExtremityIndex,out /*IDLRETVAL*/ CATIAReference oLimit);
  /**
  * Sets the limit at an Extremity of a Profile.
  * @param iExtremityIndex [in]
  *   Extremity of Profile(1-Start,2-End).
  * @param iLimit [in]
  *      New Limit to add.
  * @return
  * <code>S_OK</code> if everything ran ok
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example sets the limit at the Extremity.
  * <pre>
  * Set StiffenerLimit = ObjPart.FindObjectByName("CROSS.115")
  * Dim LimitRef As Reference
  * Set LimitRef = ObjPart.CreateReferenceFromObject(StiffenerLimit)
  * SuperStiffener.<font color="red">SetProfileLimit</font> 2, LimitRef
  * </pre>
  * </dl> 
  */
  HRESULT SetProfileLimit(in long iExtremityIndex,in CATIAReference iLimit);
  /**
  * Returns the SplitProfiles.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves SplitProfiles list of the Stiffener.
  * <pre>
  * Dim SplitStiffeners As References
  * Set SplitStiffeners = SuperStiffener.<font color="red">SplitProfiles</font>
  * Dim SplitStiffener1 As Reference
  * Set SplitStiffener1 = SplitStiffeners.Item(1)
  * Set SelctionObj = CATIA.ActiveDocument.Selection
  * SelctionObj.Add SplitStiffener1
  * Dim SplitStiff1 As SfmStiffener
  * Set SplitStiff1 = SelctionObj.FindObject("CATIASfmStiffener")
  * </pre>
  * </dl> 
  */  
#pragma PROPERTY SplitProfiles
  HRESULT get_SplitProfiles(out /*IDLRETVAL*/ CATIAReferences oSplitProfiles);
};

// Interface name : CATIASfmProfile
                                
#pragma ID CATIASfmProfile "DCE:e5ce1538-9614-4fb2-948ee06ab408c7f7"
#pragma DUAL CATIASfmProfile

// VB object name : SfmProfile (Id used in Visual Basic)
#pragma ID SfmProfile "DCE:47173f1c-ce56-41b6-bd7b17efc4cb7366"
#pragma ALIAS CATIASfmProfile SfmProfile

#endif
