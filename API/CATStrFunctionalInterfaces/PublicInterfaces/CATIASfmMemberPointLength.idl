#ifndef CATIASfmMemberPointLength_IDL
#define CATIASfmMemberPointLength_IDL
/*IDLREP*/

/**
* @CAA2Level L1
* @CAA2Usage U3
*/

#include "CATIASfmMember.idl"
#include "CATIAReference.idl"
#include "CATIALength.idl"

/**
 * Interface to manage Member created with one point, one direction and a length.
 * <b>Role</b>: To manage member created with one point, one direction and a length.
 */
interface CATIASfmMemberPointLength : CATIASfmMember
{
  /**
  * Returns or sets the point.
  * <br>Sub-element(s) supported (see @href CATIABoundary object): 
  * @href CATIAVertex.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>Point</code> the point for the <code>SfmMemberPointLength</code> feature.
  * <pre>
  * Dim Point As Reference
  * Set Point = SfmMemberPointLength.<font color="red">Point</font>
  * </pre>
  * </dl> 
  */ 
  #pragma PROPERTY Point
  HRESULT get_Point(out /*IDLRETVAL*/ CATIAReference oPoint);
  HRESULT put_Point(in CATIAReference iPoint);

  /**
  * Returns or sets the direction.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>Direction</code> the direction for the <code>SfmMemberPointLength</code> feature.
  * <pre>
  * Dim Direction As Reference
  * Set Direction = SfmMemberPointLength.<font color="red">Direction</font>
  * </pre>
  * </dl> 
  */ 
  #pragma PROPERTY Direction
  HRESULT get_Direction(out /*IDLRETVAL*/ CATIAReference oDirection);
  HRESULT put_Direction(in CATIAReference iDirection);

  /**
  * Returns or sets the direction orientation.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>DirectionOrientation</code> the direction orientation for the <code>SfmMemberPointLength</code> feature.
  * <pre>
  * Dim DirectionOrientation As Integer
  * Set DirectionOrientation = SfmMemberPointLength.<font color="red">DirectionOrientation</font>
  * </pre>
  * </dl> 
  */ 
  #pragma PROPERTY DirectionOrientation
  HRESULT get_DirectionOrientation(out /*IDLRETVAL*/ long oOrientation);
  HRESULT put_DirectionOrientation(in long iOrientation);

  /**
  * Inverts the direction orientation.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example inverts the orientation of the direction for the <code>SfmMemberPointLength</code> feature.
  * <pre>
  * SfmMemberPointLength.<font color="red">InvertDirection</font>
  * </pre>
  * </dl> 
  */ 
  HRESULT InvertDirection();

  /**
  * Returns or sets the member's length.
  *<dl>
  *<dt>Example</dt>:
  *<dd>
  * This example retrieves in <code>Length</code> the length of the <code>SfmMemberPointLength</code> feature.
  * <pre>
  * Dim Length As Double
  * Set Length = SfmMember.<font color="red">Length</font>
  * </pre>
  * </dl> 
  */ 
  #pragma PROPERTY Length
  HRESULT get_Length(out /*IDLRETVAL*/ double oLength);
  HRESULT put_Length(in double iLength);

  #pragma PROPERTY LengthParam
  HRESULT get_LengthParam(out /*IDLRETVAL*/ CATIALength oParam);
};

// Interface name : CATIASfmMemberPointLength
#pragma ID CATIASfmMemberPointLength "DCE:1ac9f3d0-ef71-4f81-a5872a670acede88"
#pragma DUAL CATIASfmMemberPointLength

// VB object name : SfmMemberPointLength (Id used in Visual Basic)
#pragma ID SfmMemberPointLength "DCE:70fefada-d230-4581-a91d2d6e9935f329"
#pragma ALIAS CATIASfmMemberPointLength SfmMemberPointLength

#endif
