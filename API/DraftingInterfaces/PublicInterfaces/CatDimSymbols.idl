/**
 * @CAA2Level L1
 * @CAA2Usage U1
 */

/**
 * Dimension line symbols.
 * <b>Role</b>: CatDimSymbols is used to specify dimension line symbols.
 * @param catDimSymbNone
 *   None. 
 * @param catDimSymbOpenArrow,
 *   Open arrow.  
 * @param catDimSymbClosedArrow,
 *   Closed arrow.
 * @param catDimSymbFilledArrow,
 *   Filled arrow.
 * @param catDimSymbSymArrow,
 *   Symmetry arrow.
 * @param catDimSymbSlash,
 *   Slash.
 * @param catDimSymbCircle,
 *   Circle.
 * @param catDimSymbFilledCircle,
 *   Filled circle.
 * @param catDimSymbScoredCircle,
 *   Sconred circle.
 * @param catDimSymbCircledCross,
 *   Circled cross.
 * @param catDimSymbTriangle,
 *   Triangle.
 * @param catDimSymbFilledTriangle,
 *   Filled triangle.
 * @param catDimSymbCross,
 *   Cross.
 * @param catDimSymbXCross,
 *   X cross.
 */
enum CatDimSymbols
{
	catDimSymbNone,
	catDimSymbOpenArrow,
	catDimSymbClosedArrow,
	catDimSymbFilledArrow,
	catDimSymbSymArrow,
	catDimSymbSlash,
	catDimSymbCircle,
	catDimSymbFilledCircle,
	catDimSymbScoredCircle,
	catDimSymbCircledCross,
	catDimSymbTriangle,
	catDimSymbFilledTriangle,
	catDimSymbCross,
	catDimSymbXCross
};
	                     
#endif
