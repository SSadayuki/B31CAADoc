#ifndef CATIADrawingTextProperties_IDL
#define CATIADrawingTextProperties_IDL

/*IDLREP*/

/**
* @CAA2Level L1
* @CAA2Usage U3
*/

#include "CATBaseDispatch.idl"
#include "CATIABase.idl"

#include "CatTextFrameType.idl"
#include "CatTextAnchorPosition.idl"
#include "CatTextProperty.idl"
#include "CatTextFlipMode.idl"
#include "CatBlankingMode.idl"
#include "CATBSTR.idl"

 /** 
  * Represents the properties of a drawing text in a drawing view.
  * <p>
  * This interface is obtained from CATIADrawingText or CATIADrawingWelding interface.
  * Update method must be called after text properties modification to refresh the visualization.
  */

interface CATIADrawingTextProperties : CATBaseDispatch
{
//------------------------------------------------------------------------------
 /**
  * Returns or sets the font name of the  drawing text.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example sets the <tt>MyText</tt> drawing text font as <tt>Courrier 10 BT</tt>.
  * <pre>
  * MyText.<font color="red">SetFontName</font>("Courrier 10 BT")
  * </pre>
  * </dl>
  */
#pragma PROPERTY FontName	 
  HRESULT get_FontName(inout /*IDLRETVAL*/ CATBSTR oFontName); 
  HRESULT put_FontName(in CATBSTR iFontName);

//------------------------------------------------------------------------------
 /**
  * Returns or sets the font size of the  drawing text.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example sets the <tt>MyText</tt> drawing text font size to <tt>3.5<tt>.
  * <pre>
  * iFontSize = 3.5
  * MyText.<font color="red">SetFontSize</font> 0, 0, iFontSize
  * </pre>
  * </dl>
  */
#pragma PROPERTY FontSize	 
  HRESULT get_FontSize(out /*IDLRETVAL*/ double oFontSize); 
  HRESULT put_FontSize(in double iFontSize);


//------------------------------------------------------------------------------
 /**
  * Returns or sets the drawing text font bold property.
  * <br>
  * <b>True</b> if the drawing text is bold formatted. 
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example get the parameter bold on <tt>MyText</tt> drawing text.
  * <pre>
  * oVal = MyText.<font color="red">Bold</font>
  * </pre>
  * </dl>
  */
#pragma PROPERTY Bold	 
  HRESULT get_Bold(out /*IDLRETVAL*/ long oVal);
  HRESULT put_Bold(in long iVal);

//------------------------------------------------------------------------------
 /**
  * Returns or sets the drawing text font italic property.
  * <br>
  * <b>True</b> if the drawing text is formatted as italic. 
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example set the parameter Italic on <tt>MyText</tt> drawing text.
  * <pre>
  * MyText.<font color="red">Italic</font> = 1
  * </pre>
  * </dl>
  */
#pragma PROPERTY Italic	 
  HRESULT get_Italic(out /*IDLRETVAL*/ long oval);
  HRESULT put_Italic(in long ival);

//------------------------------------------------------------------------------
 /**
  * Returns or sets the drawing text font underline property.
  * <br>
  * <b>True</b> if the drawing text is underlined. 
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example get the parameter bold on <tt>MyText</tt> drawing text.
  * <pre>
  * oval = MyText.<font color="red">Underline</font>
  * </pre>
  * </dl>
  */
#pragma PROPERTY Underline	 
  HRESULT get_Underline(out /*IDLRETVAL*/ long oval);
  HRESULT put_Underline(in long ival);

//------------------------------------------------------------------------------
 /**
  * Returns or sets the drawing text font overline property.
  * <br>
  * <b>True</b> if the drawing text is overlined. 
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example get the parameter Overline on <tt>MyText</tt> drawing text.
  * <pre>
  * oval = MyText.<font color="red">Overline</font>()
  * </pre>
  * </dl>
  */
#pragma PROPERTY Overline	 
  HRESULT get_Overline(out /*IDLRETVAL*/ long oval);
  HRESULT put_Overline(in long ival);

//------------------------------------------------------------------------------
 /**
  * Returns or sets the drawing text font strikethrough property.
  * <br>
  * <b>True</b> if the drawing text font is striked through. 
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example set the parameter StrikeThru on <tt>MyText</tt> drawing text.
  * <pre>
  * MyText.<font color="red">StrikeThru</font> = 1
  * </pre>
  * </dl>
  */
#pragma PROPERTY StrikeThru	 
  HRESULT get_StrikeThru(out /*IDLRETVAL*/ long oval);
  HRESULT put_StrikeThru(in long ival);

//------------------------------------------------------------------------------
 /**
  * Returns or sets the drawing text font superscript property.
  * <br>
  * <b>True</b> if the drawing text font is formatted as superscript. 
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example set the parameter Superscript on <tt>MyText</tt> drawing text.
  * <pre>
  * MyText.<font color="red">Superscript</font> = 1
  * </pre>
  * </dl>
  */
#pragma PROPERTY Superscript	 
  HRESULT get_Superscript(out /*IDLRETVAL*/ long oval);
  HRESULT put_Superscript(in long ival);

//------------------------------------------------------------------------------
 /**
  * Returns or sets the drawing text font subscript property.
  * <br>
  * <b>True</b> if the drawing text font is formatted as subscript.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example set the parameter Subscript on <tt>MyText</tt> drawing text.
  * <pre>
  * MyText.<font color="red">Subscript</font> = 1
  * </pre>
  * </dl>
  */
#pragma PROPERTY Subscript	 
  HRESULT get_Subscript(out /*IDLRETVAL*/ long oval);
  HRESULT put_Subscript(in long ival);

//------------------------------------------------------------------------------
 /**
   * Returns or sets the drawing text font justification property.
  * <br>
  * <b>True</b> if the drawing text font is justified.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example sets the Justification type of the <tt>MyText</tt> drawing text to 
  * the right
  * <pre>
  * MyText.<font color="red">Justification</font> = catRight
  * </pre>
  * </dl>
  */
#pragma PROPERTY Justification	 
  HRESULT get_Justification(out /*IDLRETVAL*/ CatJustification oJustification);
  HRESULT put_Justification(in CatJustification iJustification);


//------------------------------------------------------------------------------
 /**
  * Returns or sets the anchor point of the drawing text.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example sets the AnchorPoint of the <tt>MyText</tt> drawing text to 
  * the right
  * <pre>
  * MyText.<font color="red">AnchorPoint</font> = catRight
  * </pre>
  * </dl>
  */
#pragma PROPERTY AnchorPoint	 
  HRESULT get_AnchorPoint(out /*IDLRETVAL*/ CatTextAnchorPosition oAnchorPoint);
  HRESULT put_AnchorPoint(in CatTextAnchorPosition iAnchorPoint);

//------------------------------------------------------------------------------
 /**
  * Returns or sets the frame type of the drawing text.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example sets the frame type of the <tt>MyText</tt> drawing text to 
  * an ellipse
  * <pre>
  * MyText.<font color="red">FrameType</font> = catEllipse
  * </pre>
  * </dl>
  */
#pragma PROPERTY FrameType	 
  HRESULT get_FrameType(out /*IDLRETVAL*/ CatTextFrameType oTextFrameType);
  HRESULT put_FrameType(in CatTextFrameType iTextFrameType);

//------------------------------------------------------------------------------
 /**
  * Activates the text frame of the drawing text.
  * @param iType
  *   The text frame type
  * <!-- @sample -->
  * </dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example add a rectangle frame to <tt>MyText</tt> drawing text.
  * <pre>
  * CatTextFrameType itype = catRectangle
  * MyText.<font color="red">ActivateFrame</font> itype
  * </pre>
  * @sample
  * This example remove the frame to <tt>MyText</tt> drawing text.
  * <pre>
  * CatTextFrameType itype = catNone
  * MyText.<font color="red">ActivateFrame</font> itype
  * </pre>
  * </dl>
  */
  HRESULT ActivateFrame(in CatTextFrameType iType);

//------------------------------------------------------------------------------
 /**
  * @nodoc Not yet implemented. Do not use.
  * Returns or sets the frame Name of the drawing text.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example sets the frame type of the <tt>MyText</tt> drawing text to 
  * an ellipse
  * <pre>
  * MyText.<font color="red">SetFrameName</font>("Variable_Rectangle")
  * </pre>
  * </dl>
  */
#pragma PROPERTY FrameName	 
  HRESULT get_FrameName(inout /*IDLRETVAL*/ CATBSTR oFontName); 
  HRESULT put_FrameName(in CATBSTR iFontName);

//------------------------------------------------------------------------------
 /**
  * Returns or sets the color of the drawing text.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example sets the Color type of the <tt>MyText</tt> drawing text to red
  * <pre>
  * redCol  =-16776961 'Encoded RGBA color within long integer (R=255 G=0   B=0   A=255)
  * MyText.<font color="red">Color</font> = redCol
  * </pre>
  * </dl>
  */
#pragma PROPERTY Color
  HRESULT get_Color(out /*IDLRETVAL*/ long oColor);
  HRESULT put_Color(in long iColor);

 /**
  * Font kerning property.
  * <br>
  * <b>True</b> if the drawing text font is formatted as kerning
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example set the parameter kerning on <tt>MyText</tt> drawing text.
  * <pre>
  * MyText.<font color="red">Kerning</font> = 1
  * </pre>
  * </dl>
  */
#pragma PROPERTY Kerning	 
  HRESULT get_Kerning(out /*IDLRETVAL*/ long oVal);
  HRESULT put_Kerning(in long iVal);

  //------------------------------------------------------------------------------
  /**
  * Returns or sets the mirroring of the drawing text.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example sets the Mirror type of the <tt>MyText</tt> drawing text to no flip
  * <pre>
  * MyText.<font color="red">Mirror</font> = catTextNoFlip
  * </pre>
  * </dl>
  */
#pragma PROPERTY Mirror
  HRESULT get_Mirror(out /*IDLRETVAL*/ CatTextFlipMode oMirrorMode);
  HRESULT put_Mirror(in CatTextFlipMode iMirrorMode);

  /**
  * Update the properties of the drawing text.
  * <!-- @sample -->
  * </dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example update the properties to <tt>MyText</tt> drawing text.
  * <pre>
  * MyText.<font color="red">Update</font> 
  * </pre>
  * </dl>
  */
  HRESULT Update();

  //------------------------------------------------------------------------------
  /**
  * Returns or sets the blanking mode of the drawing text.
  * <!-- @sample -->
  * <dl>
  * <dt><b>Example:</b>
  * <dd>
  * This example sets the blanking mode type of <tt>MyText</tt> drawing text to active on geom
  * <pre>
  * MyText.<font color="red">Blanking</font> = catBlankingOnGeom
  * </pre>
  * </dl>
  */
#pragma PROPERTY Blanking
  HRESULT get_Blanking(out /*IDLRETVAL*/ CatBlankingMode oBlanking);
  HRESULT put_Blanking(in CatBlankingMode iBlanking);
};

#pragma ID CATIADrawingTextProperties "DCE:92a3e2ae-293f-11d3-ad44006094eb80b5"
#pragma DUAL CATIADrawingTextProperties

// Visual Basic name
#pragma ID DrawingTextProperties "DCE:9225860c-293f-11d3-ad44006094eb80b5"
#pragma ALIAS CATIADrawingTextProperties DrawingTextProperties

#endif
