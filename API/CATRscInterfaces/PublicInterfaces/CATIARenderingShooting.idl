/**
 * Render the shooting
 *<br>
 * Caution: Product involved in rendering calculation should not be closed
 * before the end of computation. If product is closed, calculation is interrupted.
 */
  HRESULT  Render ();

};

// Interface Name : CATIARenderingShooting
#pragma ID CATIARenderingShooting "DCE:a51f06a0-999a-11d6-805e0030f113d1bf"
#pragma DUAL CATIARenderingShooting
 
// VB Object Name : RenderingShooting
#pragma ID RenderingShooting "DCE:ae3ded20-999a-11d6-805e0030f113d1bf"
#pragma ALIAS CATIARenderingShooting RenderingShooting

#endif
// CATIARenderingShooting_IDL







