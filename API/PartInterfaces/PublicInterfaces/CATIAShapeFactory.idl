  //      V5R8 Only: ADD A NEW RECTANGULAR PATTERN OF LIST
  //      -----------------------------------------------
  //
  /**
  * V5R8 Only: Creates and returns a new rectangular pattern within the current body using a list of shapes.
  * @param iShapeToCopy
  *   The shape to be copied by the rectangular pattern
  *   Others shapes will be add by put_ItemToCopy with CATIAPattern interface
  * @param iNbOfCopiesInDir1
  *   The number of times <tt>iShapeToCopy</tt> will be copied along
  *   the pattern first direction
  * @param iNbOfCopiesInDir2
  *   The number of times <tt>iShapeToCopy</tt> will be copied along
  *   the pattern second direction
  * @param iStepInDir1
  *   The distance that will separate two consecutive copies in the pattern
  *   along its first direction
  * @param iStepInDir2
  *   The distance that will separate two consecutive copies in the pattern
  *   along its second direction
  * @param iShapeToCopyPositionAlongDir1
  *   Specifies the position of the original shape <tt>iShapeToCopy</tt>
  *   among its copies along <tt>iDir1</tt>
  * @param iShapeToCopyPositionAlongDir2
  *   Specifies the position of the original shape <tt>iShapeToCopy</tt>
  *   among its copies along <tt>iDir2</tt>
  * @param iDir1
  *   The line or linear edge that specifies the pattern first repartition
  *   direction
  * @param iDir2
  *   The line or linear edge that specifies the pattern second repartition
  *   direction
  * @param iIsReversedDir1
  *   The boolean flag indicating whether the natural orientation of
  *   <tt>iDir1</tt> should be used to orient the pattern operation.
  *   True indicates that <tt>iShapeToCopy</tt> is copied in the
  *   direction of the natural orientation of <tt>iDir1</tt>.
  * @param iIsReversedDir2
  *   The boolean flag indicating whether the natural orientation of 
  *   <tt>iDir2</tt> should be used to orient the pattern operation.
  *   True indicates that <tt>iShapeToCopy</tt> is copied in the 
  *   direction of the natural orientation of <tt>iDir2</tt>.
  * @param iRotationAngle
  *   The angle applied to both directions <tt>iDir1</tt> and <tt>iDir2</tt>
  *   prior to applying the pattern. 
  *   The original shape <tt>iShapeToCopy</tt> is used as the rotation center.
  *   Nevertheless, the copied shapes themselves are not rotated.
  *   This allows the definition of a rectangular pattern 
  *   relatively to existing geometry, but not necessarily parallel to it.
  * @return The created rectangular pattern
  */ 

  HRESULT AddNewRectPatternofList
    ( in CATIABase                   	iShapeToCopy
    , in long				iNbOfCopiesInDir1
    , in long				iNbOfCopiesInDir2
    , in double				iStepInDir1
    , in double				iStepInDir2
    , in long				iShapeToCopyPositionAlongDir1
    , in long				iShapeToCopyPositionAlongDir2
    , in CATIAReference			iDir1
    , in CATIAReference			iDir2
    , in boolean				iIsReversedDir1
    , in boolean				iIsReversedDir2
    , in double				iRotationAngle
    , out /*IDLRETVAL*/ CATIARectPattern	oNewRectPattern
    );

  //      V5R8 Only: ADD A NEW CIRCULAR PATTERN  OF LIST
  //      -----------------------------------------------
  //
  /**
  * V5R8 Only: Creates and returns a new circular pattern within the current body using a list of shapes.
  * @param iShapeToCopy
  *   The shape to be copied by the circular pattern.
  *   Others shapes will be add by put_ItemToCopy with CATIAPattern interface
  * @param iNbOfInstancesInRadialDir
  *   The number of times <tt>iShapeToCopy</tt> will be copied along
  *   pattern radial direction
  * @param iNbOfInstancesInAngularDir
  *   The number of times <tt>iShapeToCopy</tt> will be copied along
  *   pattern angular direction
  * @param iStepInRadialDir
  *   The distance that will separate two consecutive copies in the pattern
  *   along its radial direction
  * @param iStepInAngularDir
  *   The angle that will separate two consecutive copies in the pattern
  *   along its angular direction
  * @param iShapeToCopyPositionAlongRadialDir
  *   Specifies the position of the original shape <tt>iShapeToCopy</tt>
  *   among its copies along the radial direction
  * @param iShapeToCopyPositionAlongAngularDir
  *   Specifies the position of the original shape <tt>iShapeToCopy</tt>
  *   among its copies along the angular direction
  * @param iRotationCenter
  *   The point or vertex that specifies the pattern center of rotation
  * @param iRotationAxis
  *   The line or linear edge that specifies the axis around which instances
  *   will be rotated relative to each other
  * @param iIsReversedRotationAxis
  *   The boolean flag indicating wether the natural orientation of 
  *   <tt>iRotationAxis</tt> should be used to orient the pattern operation.
  *   A value 
  *   of true indicates that <tt>iItemToDuplicate</tt> are copied in the 
  *   direction of the natural orientation of <tt>iRotationAxis</tt>.
  * @param iRotationAngle
  *   The angle applied to the direction <tt>iRotationAxis</tt> 
  *   prior to applying the pattern.
  *   The original shape <tt>iShapeToCopy</tt> is used as the rotation center.
  *   Nevertheless, the copied shapes themselves are not rotated.
  *   This allows the definition of a circular pattern 
  *   relatively to existing geometry, but not necessarily parallel to it.
  * @param iIsRadiusAligned
  *   The boolean flag that specifies whether the instances
  *   of <tt>iItemToDuplicate</tt>
  *   copied by the pattern should be kept parallel to each other (True)
  *   or if they should 
  *   be aligned with the radial direction they lie upon (False).
  * @return The created circular pattern
  */ 
  HRESULT AddNewCircPatternofList
    ( in CATIABase                          iShapeToCopy
    , in long                               iNbOfCopiesInRadialDir
    , in long                               iNbOfCopiesInAngularDir
    , in double                             iStepInRadialDir
    , in double                             iStepInAngularDir
    , in long                               iShapeToCopyPositionAlongRadialDir
    , in long                               iShapeToCopyPositionAlongAngularDir
    , in CATIAReference			iRotationCenter
    , in CATIAReference			iRotationAxis
    , in boolean                            iIsReversedRotationAxis
    , in double                             iRotationAngle
    , in boolean				iIsRadiusAligned
    , out /*IDLRETVAL*/ CATIACircPattern    oNewCircPattern);


  //      V5R8 Only: ADD A NEW USER PATTERN OF LIST
  //      ------------------------------------------
  //
  /**
  * V5R8 Only: Creates and returns a new user pattern within the current body using a list of shapes.
  * @param iShapeToCopy
  *   The shape to be copied by the user pattern
  *   Others shapes will be add by put_ItemToCopy with CATIAPattern interface
  * @param iNbOfCopies
  *   The number of times <tt>iShapeToCopy</tt> will be copied
  * @return The created user pattern
  */ 

  HRESULT AddNewUserPatternofList 
    ( in CATIABase                   	iShapeToCopy
    , in long				iNbOfCopies
    , out /*IDLRETVAL*/ CATIAUserPattern	oNewUserPattern
    );


