  //                        , out /*IDLRETVAL*/ CATIARectPattern    oNewRectPattern
  //                        );

  //      ADD A NEW CIRCULAR PATTERN
  //      --------------------------
  //
  /**
  * Creates and returns a new circular pattern within the current body.
  * @param iShapeToCopy
  *   The shape to be copied by the circular pattern
  * @param iNbOfInstancesInRadialDir
  *   The number of times <tt>iShapeToCopy</tt> will be copied along
  *   pattern radial direction
  * @param iNbOfInstancesInAngularDir
  *   The number of times <tt>iShapeToCopy</tt> will be copied along
  *   pattern angular direction
  * @param iStepInRadialDir
  *   The distance that will separate two consecutive copies in the pattern
  *   along its radial direction
  * @param iStepInAngularDir
  *   The angle that will separate two consecutive copies in the pattern
  *   along its angular direction
  * @param iShapeToCopyPositionAlongRadialDir
  *   Specifies the position of the original shape <tt>iShapeToCopy</tt>
  *   among its copies along the radial direction
  * @param iShapeToCopyPositionAlongAngularDir
  *   Specifies the position of the original shape <tt>iShapeToCopy</tt>
  *   among its copies along the angular direction
  * @param iRotationCenter
  *   The point or vertex that specifies the pattern center of rotation
  * @param iRotationAxis
  *   The line or linear edge that specifies the axis around which instances
  *   will be rotated relative to each other<br>
  * The following @href CATIABoundary objects are supported: 
  * @href CATIAPlanarFace , @href CATIACylindricalFace , @href CATIARectilinearTriDimFeatEdge and @href CATIARectilinearBiDimFeatEdge.
  * @param iIsReversedRotationAxis
  *   The boolean flag indicating wether the natural orientation of 
  *   <tt>iRotationAxis</tt> should be used to orient the pattern operation.
  *   A value 
  *   of true indicates that <tt>iItemToDuplicate</tt> are copied in the 
  *   direction of the natural orientation of <tt>iRotationAxis</tt>.
  * @param iRotationAngle
  *   The angle applied to the direction <tt>iRotationAxis</tt> 
  *   prior to applying the pattern.
  *   The original shape <tt>iShapeToCopy</tt> is used as the rotation center.
  *   Nevertheless, the copied shapes themselves are not rotated.
  *   This allows the definition of a circular pattern 
  *   relatively to existing geometry, but not necessarily parallel to it.
  * @param iIsRadiusAligned
  *   The boolean flag that specifies whether the instances
  *   of <tt>iItemToDuplicate</tt>
  *   copied by the pattern should be kept parallel to each other (True)
  *   or if they should 
  *   be aligned with the radial direction they lie upon (False).
  * @return The created circular pattern
  */ 
  HRESULT AddNewCircPattern
    ( in CATIABase                          iShapeToCopy
    , in long                               iNbOfCopiesInRadialDir
    , in long                               iNbOfCopiesInAngularDir
    , in double                             iStepInRadialDir
    , in double                             iStepInAngularDir
    , in long                               iShapeToCopyPositionAlongRadialDir
    , in long                               iShapeToCopyPositionAlongAngularDir
    , in CATIAReference			iRotationCenter
    , in CATIAReference			iRotationAxis
    , in boolean                            iIsReversedRotationAxis
    , in double                             iRotationAngle
    , in boolean				iIsRadiusAligned
    , out /*IDLRETVAL*/ CATIACircPattern    oNewCircPattern);
  //                        ( in CATIABase                          iItemToDuplicate
  //                        , in long                               iNbOfInstancesInRadialDir
  //                        , in long                               iNbOfInstancesInAngularDir
  //                        , in double                             iStepInRadialDir
  //                        , in double                             iStepInAngularDir
  //                        , in long                               iAnchorRowInRadialDir 
  //                        , in long                               iAnchorRowInAngularDir
  //            , in CATIAReference         iRotationCenter
  //            , in CATIAReference         iRotationAxis
  //                        , in boolean                            iIsReversedRotationAxis
  //                        , in double                             iRotationAngle
  //            , in boolean                iIsRadiusAligned
  //                        , out /*IDLRETVAL*/ CATIACircPattern    oNewCircPattern);


