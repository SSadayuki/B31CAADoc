  * @param iSewingSide
  *   The specification for which side of the current volume should be kept
  *   at the end of the sewing operation
  * @return The created sewing operation
  */
  HRESULT AddNewVolumeSewSurface   ( in long iType
    , in CATIAReference				   iSupportVolume 
    , in CATIAReference                  iSewingElement
    , in CatSplitSide                    iSewingSide
    , out /*IDLRETVAL*/ CATIASewing       oNewSewing
    );

