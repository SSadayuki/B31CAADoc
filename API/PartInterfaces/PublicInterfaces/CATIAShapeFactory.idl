  *   during the shell process, except for those to be removed
  * @param iExternaThickness
  *   The thickness of material to be added on the external side of all the faces
  *   during the shell process, except for those to be removed
  * @param iVolumeSupport
  *   The Volume related the faces to remove and faces to thicken
  * @return The created Volumic Shell.
  */
  HRESULT AddNewVolumeShell	(in CATIAReference    iFaceToRemove,
    in double            iInternalThickness,
    in double            iExternalThickness,
    in CATIAReference    iVolumeSupport, 
    out /*IDLRETVAL*/ CATIAShell       oNewShell);

