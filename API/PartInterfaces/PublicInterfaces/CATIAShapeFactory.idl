  //  ----------------------------------------------------
  //  --  S O L I D   F I L L E T   C R E A T I O N  --
  //  ----------------------------------------------------
  //
  //  ADD A NEW FACE FILLET
  //  ---------------------
  //
  /**
  * Creates and returns a new solid face-to-face fillet.
  * <br>
  * Use this method to created face-to-face fillets with varying fillet radii,
  * by editing fillet attributes driving its radius after its creation.
  * @param iF1
  *   The first face that will support the fillet<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iF2
  *   The second face that will support the fillet<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iRadius
  *   The fillet radius
  * @return The created face-to-face fillet
  */
  HRESULT AddNewSolidFaceFillet( in    CATIAReference                  iF1
    , in    CATIAReference                  iF2 
    , in    double              iRadius
    , out /*IDLRETVAL*/ CATIAFaceFillet oNewFillet
    );


  //
  //  ADD A NEW EDGE FILLET (CONSTANT RADIUS)
  //  ---------------------------------------
  //
  /**
  * Creates and returns a new solid edge fillet with a constant radius.
  * within the current body.
  * @param iEdgeToFillet
  *   The edge that will be filleted first<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIATriDimFeatEdge.
  * @param iPropagMode
  *   Controls whether other edges found adjacent to the 
  *   first one should also be filleted in the same operation
  * @param iRadius
  *   The fillet radius
  * @return The created edge fillet
  */
  HRESULT AddNewSolidEdgeFilletWithConstantRadius
    ( in    CATIAReference                          iEdgeToFillet
    , in    CatFilletEdgePropagation        iPropagMode
    , in    double                  iRadius
    , out /*IDLRETVAL*/ CATIAConstRadEdgeFillet     oNewFillet
    );


  //
  //  ADD A NEW EDGE FILLET (VARYING RADIUS)
  //  --------------------------------------
  //
  /**
  * Creates and returns a new solid edge fillet with a varying radius.
  * within the current body.
  * @param iEdgeToFillet
  *   The edge that will be filleted first<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIATriDimFeatEdge.
  * @param iPropagMode
  *   Controls whether other edges found adjacent to the 
  *   first one should also be filleted in the same operation
  * @param iVariationMode
  *   Controls the law of evolution for the fillet radius 
  *   between specified control points, such as edges extremities
  * @param iDefaultRadius
  *   The fillet default radius, that will apply when no other radius can 
  *   be inferred from the <tt>iVariationMode</tt> parameter
  * @return The created edge fillet
  */

  HRESULT AddNewSolidEdgeFilletWithVaryingRadius
    ( in    CATIAReference                          iEdgeToFillet
    , in    CatFilletEdgePropagation        iPropagMode
    , in    CatFilletVariation          iVariationMode
    , in    double                  iDefaultRadius
    , out /*IDLRETVAL*/ CATIAVarRadEdgeFillet       oNewFillet
    );


  //
  //  ADD A NEW TRITANGENT FILLET
  //  ---------------------------
  //
  /**
  // * Creates and returns a new solid tritangent fillet within the current body.
  // * <br>
  // * This kind of fillet begins with tangency on a first face <tt>iF1</tt>, 
  // * gets tangent to a second one <tt>iRemovedFace</tt>
  // * and ends with tangency to a third one <tt>iF2</tt>. 
  // * During the process the 
  // * second face <tt>iRemovedFace</tt> is removed. 
  // * @param iF1
  // *    The starting face for the fillet<br>
  // * The following @href CATIABoundary object is supported: 
  // * @href CATIAFace.
  // * @param iF2
  // *    The ending face for the fillet<br>
  // * The following @href CATIABoundary object is supported: 
  // * @href CATIAFace.
  // * @param iRemovedFace
  // *    The face used as an intermediate tangent support for the fillet 
  // *    during its course from <tt>iF1</tt> to <tt>iF2</tt>. This face will be 
  // *    removed at the end of the filleting operation.<br>
  // * The following @href CATIABoundary object is supported: 
  // * @href CATIAFace
  // * @return The created tritangent fillet
  */

  HRESULT AddNewSolidTritangentFillet
    ( in    CATIAReference                          iF1
    , in    CATIAReference                          iF2 
    , in    CATIAReference                          iRemovedFace
    , out /*IDLRETVAL*/ CATIATritangentFillet   oNewFillet
    );



  //  ----------------------------------------------------
  //  --  S U R F A C E   F I L L E T  C R E A T I O N  --
  //  ----------------------------------------------------
  //
  //  ADD A NEW FACE FILLET
  //  ---------------------
  //
  /**
  * Creates and returns a new surface face-to-face fillet.
  * <br>
  * Use this method to created face-to-face fillets with varying fillet radii,
  * by editing fillet attributes driving its radius after its creation.
  * @param iF1
  *   The first face that will support the fillet<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iF2
  *   The second face that will support the fillet<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iRadius
  *   The fillet radius
  * @return The created face-to-face fillet
  */
  HRESULT AddNewSurfaceFaceFillet( in    CATIAReference                  iF1
    , in    CATIAReference                  iF2 
    , in    double              iRadius
    , out /*IDLRETVAL*/ CATIAFaceFillet oNewFillet
    );


  //
  //  ADD A NEW EDGE FILLET (CONSTANT RADIUS)
  //  ---------------------------------------
  //
  /**
  * Creates and returns a new surface edge fillet with a constant radius.
  * within the current body.
  * @param iEdgeToFillet
  *   The edge that will be filleted first<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIATriDimFeatEdge.
  * @param iPropagMode
  *   Controls whether other edges found adjacent to the 
  *   first one should also be filleted in the same operation
  * @param iRadius
  *   The fillet radius
  * @return The created edge fillet
  */
  HRESULT AddNewSurfaceEdgeFilletWithConstantRadius
    ( in    CATIAReference                          iEdgeToFillet
    , in    CatFilletEdgePropagation        iPropagMode
    , in    double                  iRadius
    , out /*IDLRETVAL*/ CATIAConstRadEdgeFillet     oNewFillet
    );


  //
  //  ADD A NEW EDGE FILLET (VARYING RADIUS)
  //  --------------------------------------
  //
  /**
  * Creates and returns a new surface edge fillet with a varying radius.
  * within the current body.
  * @param iEdgeToFillet
  *   The edge that will be filleted first<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIATriDimFeatEdge.
  * @param iPropagMode
  *   Controls whether other edges found adjacent to the 
  *   first one should also be filleted in the same operation
  * @param iVariationMode
  *   Controls the law of evolution for the fillet radius 
  *   between specified control points, such as edges extremities
  * @param iDefaultRadius
  *   The fillet default radius, that will apply when no other radius can 
  *   be inferred from the <tt>iVariationMode</tt> parameter
  * @return The created edge fillet
  */

  HRESULT AddNewSurfaceEdgeFilletWithVaryingRadius
    ( in    CATIAReference                          iEdgeToFillet
    , in    CatFilletEdgePropagation        iPropagMode
    , in    CatFilletVariation          iVariationMode
    , in    double                  iDefaultRadius
    , out /*IDLRETVAL*/ CATIAVarRadEdgeFillet       oNewFillet
    );


  //
  //  ADD A NEW TRITANGENT FILLET
  //  ---------------------------
  //
  /**
  // * Creates and returns a new surface tritangent fillet within the current body.
  // * <br>
  // * This kind of fillet begins with tangency on a first face <tt>iF1</tt>, 
  // * gets tangent to a second one <tt>iRemovedFace</tt>
  // * and ends with tangency to a third one <tt>iF2</tt>. 
  // * During the process the 
  // * second face <tt>iRemovedFace</tt> is removed. 
  // * @param iF1
  // *    The starting face for the fillet<br>
  // * The following @href CATIABoundary object is supported: 
  // * @href CATIAFace.
  // * @param iF2
  // *    The ending face for the fillet<br>
  // * The following @href CATIABoundary object is supported: 
  // * @href CATIAFace.
  // * @param iRemovedFace
  // *    The face used as an intermediate tangent support for the fillet 
  // *    during its course from <tt>iF1</tt> to <tt>iF2</tt>. This face will be 
  // *    removed at the end of the filleting operation.<br>
  // * The following @href CATIABoundary object is supported: 
  // * @href CATIAFace
  // * @return The created tritangent fillet
  */

  HRESULT AddNewSurfaceTritangentFillet
    ( in    CATIAReference                          iF1
    , in    CATIAReference                          iF2 
    , in    CATIAReference                          iRemovedFace
    , out /*IDLRETVAL*/ CATIATritangentFillet   oNewFillet
    );

  //
  //      ADD A NEW VOLUME THICKNESS
  //      -------------------
  //
  /**
  * Creates and returns a volume new thickness within the current GS or OGS.
  * @param iFaceToThicken
  *   The first face to thicken in the thickening process.   
  *   <br>
  *   New faces to thicken can be added to the thickness afterwards by using 
  *   methods offered by the created thickness<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iOffset
  *   The thickness of material to be added on the external side of the face
  *   <tt>iFaceToThicken</tt> during the thickening process
  * @param iType
  *   The mode of thickness creation (4=Volume)
  * @param iVolumeSupport
  *   The support volume for volumic draft
  * @return The created thickness
  */
  HRESULT AddNewVolumeThickness
    ( in CATIAReference                iFaceToThicken
    , in double                        iOffset
    , in long								iType
    , in CATIAReference						iVolumeSupport
    , out /*IDLRETVAL*/ CATIAThickness oNewThickness
    );

  //
  //	ADD A NEW AUTOFILLET
  //	---------------------------
  //
  /**
  * Creates and returns a new solid autofillet.
  * <br>
  * Use this method to create autofillet by providing fillet and round radius values.
  * @param iFilletRadius
  *   The fillet radius
  * @param iRoundRadius 
  *   The round radius
  * @return The created autofillet
  */
  HRESULT AddNewAutoFillet(in double iFilletRadius,
    in double iRoundRadius,
    out /*IDLRETVAL*/ CATIAAutoFillet  oNewFillet );

  /** 
  * Creates and returns an AxisToAxis transformation feature.
  * @param iReference
  *	The refrence axis.
  * @param iTarget
  *	The target axis.
  * @return The created AxisToAxis transformation feature.
  */ 

  HRESULT AddNewAxisToAxis2 (in      CATIAReference   iReference,
    in      CATIAReference            iTarget,
    out /*IDLRETVAL*/ CATIABase oAxisToAxis);

  /** 
  * Creates and returns a Affinity feature.
  * @param XRatio
  *	Value for the XRatio.
  * @param YRatio
  *	Value for the YRatio.
  * @param ZRatio
  *	Value for the ZRatio.
  * @return the created Affinity feature.
  */ 

  HRESULT AddNewAffinity2 (in      double XRatio,
    in      double YRatio,
    in      double ZRatio,
    out /*IDLRETVAL*/ CATIABase oAffinity);

  //
  //	ADD A NEW AUTODRAFT
  //	---------------------------
  //
  /**
  * Creates and returns a new solid autodraft.
  * <br>
  * Use this method to create autodraft by providing draft angle.
  * @param iDraftAngle
  *   The draft angle.
  * @return The created autodraft.
  */
  HRESULT AddNewAutoDraft(in double iDraftAngle, out /*IDLRETVAL*/ CATIAAutoDraft  oNewDraft );

  //
  //	ADD A NEW SURFACIC AUTOFILLET
  //	---------------------------
  //
  /**
  * Creates and returns a new Surfacic autofillet.
  * <br>
  * Use this method to create autofillet by providing fillet radius value.
  * @param iFilletRadius
  *   The fillet radius
  * @return The created autofillet
  */
  HRESULT AddNewSurfacicAutoFillet(in double iFilletRadius,out /*IDLRETVAL*/ CATIAAutoFillet  oNewFillet);
	
	//      ADD A NEW SURFACIC SEWING FEATURE
  //      -------------------------------
  //
  /**
  * Creates and returns a new volume sewing operation within the current OGS/GS.
  * @param iType
  *   Parameter to determine the sewing type. For Volume sewing Type = 4
  * @param iSupportSurface
  *   The surfacic support on which sew operation will be performed
  * @param iSewingElement
  *   The face or skin or surface that will be sewn on the current volume support
  * @param iSewingSide
  *   The specification for which side of the current volume should be kept
  *   at the end of the sewing operation
  * @return The created sewing operation
  */
  HRESULT AddNewSurfacicSewSurface   ( in long iType
    , in CATIAReference				   iSupportSurface 
    , in CATIAReference                  iSewingElement
    , in CatSplitSide                    iSewingSide
    , out /*IDLRETVAL*/ CATIASewing       oNewSewing
    );

  //      ADD A NEW DEFEATURING FEATURE
  //      -------------------------------
  //
  /**
  * Creates and returns a new defeaturing operation within the current container.
  * @return The created defeaturing operation
  */
  HRESULT AddNewDefeaturing   ( out /*IDLRETVAL*/ CATIADefeaturing oNewDefeaturing );

};
// Interface Name : CATIAShapeFactory
#pragma ID CATIAShapeFactory "DCE:81463c0e-bbca-0000-0280030ba6000000"
#pragma DUAL CATIAShapeFactory

// VB Object Name : ShapeFactory
#pragma ID ShapeFactory "DCE:81463c13-05a6-0000-0280030ba6000000"
#pragma ALIAS CATIAShapeFactory ShapeFactory


