#include "CATIAFactory.idl"
#include "CATFilletDefs.idl"
#include "CATDraftDefs.idl"
#include "CATChamferDefs.idl"
#include "CATSplitDefs.idl"

interface CATIAShape;
interface CATIASketch;
//
interface CATIAPad;
interface CATIAPocket;
//
interface CATIAHole;
//
interface CATIAShaft;
interface CATIAGroove;
//
interface CATIARib;
interface CATIASlot;
interface CATIAStiffener;
//
interface CATIAFaceFillet;
//
interface CATIAGeometricElement;
// interface CATIAGeometry3D;
interface CATIAScaling;
//
interface CATIAConstRadEdgeFillet;
interface CATIAVarRadEdgeFillet;
//
interface CATIATritangentFillet;
//
interface CATIADraft;
interface CATIAShell;
interface CATIAThickness;
interface CATIAChamfer;
//
interface CATIABody;
interface CATIAAdd;
interface CATIAAssemble;
interface CATIACloseSurface;
interface CATIARemove;
interface CATIAIntersect;
interface CATIATrim;
//
interface CATIASplit;
interface CATIASewing;
interface CATIAThickSurface;
interface CATIAThread;
//
interface CATIAMirror;
interface CATIARectPattern;
interface CATIACircPattern;
interface CATIAUserPattern;
interface CATIABase;

interface CATIARemoveFace;
interface CATIASolidCombine;
interface CATIAReplaceFace;

interface CATIAReference;

interface CATIAAutoFillet;
interface CATIAAutoDraft;
interface CATIADefeaturing;
//-----------------------------------------------------------------
/**
* Represents the factory for shapes to create all kinds of shapes
* that may be needed for part design.
* <br>
* The Shapefactory mission is to build from scratch shapes that 
* will be used within the design process of parts. Those shapes have a 
* strong mechanical built-in knowledge, such as chamfer or hole, and in 
* most cases apply contextually to the part being designed. When created, 
* they become part of the definition of whichever <i>body</i> or
* <i>shape</i> that is current at that time. After they are created, they 
* become in turn the current <i>body</i> or <i>shape</i>.
* In most cases, shapes are created from a factory with a minimum number 
* of parametersr. Other shapes parameters may be set further on by using 
* methods offered by the shape itself.
*/
interface CATIAShapeFactory : CATIAFactory
{

  //      =============
  //      == METHODS ==
  //      =============
  //
  /**
  * @section Sketch-based shapes 
  */
  //  ---------------------------
  //  --  P R I S M  CREATION  --
  //  ---------------------------
  //
  //  ADD A NEW PAD
  //  -------------
  //
  /**
  * Creates and returns a new pad within the current body.
  * @param iSketch
  *   The sketch defining the pad base
  * @param iHeight
  *   The pad height
  * @return The created pad
  */
  HRESULT AddNewPad   ( in    CATIASketch iSketch
    , in    double      iHeight
    , out /*IDLRETVAL*/ CATIAPad oNewPad
    );


  //
  //  ADD A NEW POCKET
  //  ----------------
  //
  /**
  * Creates and returns a new pocket within the current shape.
  * @param iSketch
  *   The sketch defining the pocket base
  * @param iDepth
  *   The pocket depth
  * @return The created pocket
  */
  HRESULT AddNewPocket    ( in    CATIASketch iSketch
    , in    double      iHeight
    , out /*IDLRETVAL*/ CATIAPocket oNewPocket
    );

  //
  //  ADD A NEW PAD FROM REFERENCE
  //  ----------------------------
  //
  /**
  * Creates and returns a new pad within the current body.
  * @param iProfileElt
  *   The reference on the element defining the pad base
  * @param iHeight
  *   The pad height
  * @return The created pad
  */
  HRESULT AddNewPadFromRef   ( in    CATIAReference iProfileElt
    , in    double      iHeight
    , out /*IDLRETVAL*/ CATIAPad oNewPad
    );


  //
  //  ADD A NEW POCKET FROM REFERENCE
  //  -------------------------------
  //
  /**
  * Creates and returns a new pocket within the current shape.
  * @param iProfileElt
  *   The reference on the element defining the pocket base
  * @param iDepth
  *   The pocket depth
  * @return The created pocket
  */
  HRESULT AddNewPocketFromRef    ( in    CATIAReference iProfileElt
    , in    double      iHeight
    , out /*IDLRETVAL*/ CATIAPocket oNewPocket
    );


  //  -------------------------
  //  --  H O L E  CREATION  --
  //  -------------------------
  //
  //  ADD A NEW HOLE
  //  --------------
  //
  /**
  * Creates and returns a new hole within the current shape.
  * <br>
  * Actual hole shape is defined by editing hole properties after its
  * creation.
  * @param iSupport
  *   The support defining the hole reference plane.
  *   <br>
  *   Anchor point is located at the barycenter of the support. 
  *   The hole axis in 3D passes through that point and is normal to the plane.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iDepth
  *   The hole depth.
  * @return The created hole
  */
  HRESULT AddNewHole (
    in CATIAReference iSupport,
    in double         iDepth,
    out /*IDLRETVAL*/ CATIAHole oNewHole
    );

  /**
  * Creates and returns a new hole within the current shape.
  * <br>
  * Actual hole shape is defined by editing hole properties after its
  * creation.
  * @param iX
  *   Origin point x absolute coordinate
  * @param iY
  *   Origin point y absolute coordinate
  * @param iZ
  *   Origin point z absolute coordinate
  *   <br>
  *   Sets the origin point which the hole is anchored to.<br> 
  *   If mandatory, the entry point will be projected onto a tangent plane.
  * @param iSupport
  *   The support defining the hole reference plane.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iDepth
  *   The hole depth.
  * @return The created hole
  */
  HRESULT AddNewHoleFromPoint (
    in double iX, in double iY, in double iZ,
    in CATIAReference iSupport,
    in double         iDepth,
    out /*IDLRETVAL*/ CATIAHole oNewHole
    );

  /**
  * Creates and returns a new hole within the current shape.
  * <br>
  * Actual hole shape is defined by editing hole properties after its
  * creation.
  * @param iOrigin
  *   The origin point which the hole is anchored to.
  * @param iSupport
  *   The support defining the hole reference plane.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iDepth
  *   The hole depth.
  * @return The created hole
  */
  HRESULT AddNewHoleFromRefPoint (
    in CATIAReference iOrigin,
    in CATIAReference iSupport,
    in double         iDepth,
    out /*IDLRETVAL*/ CATIAHole oNewHole
    );

  /**
  * Creates and returns a new hole within the current shape.
  * <br>
  * Actual hole shape is defined by editing hole properties after its
  * creation.
  * @param iX
  *   Origin point x absolute coordinate
  * @param iY
  *   Origin point y absolute coordinate
  * @param iZ
  *   Origin point z absolute coordinate
  *   <br>
  *   Sets the origin point which the hole is anchored to.<br> 
  *   If mandatory, the entry point will be projected onto a tangent plane.
  * @param iEdge
  *   The edge which the hole is constrained to.
  *   <br>
  *   If edge is circular, the origin of the hole will be concentric
  *   to the edge (iX, iY, iZ will be overridden).
  *   if not, the origin of the hole will have a length constraint with
  *   the edge.<br>
  *   The following @href CATIABoundary object is supported: 
  *   @href CATIATriDimFeatEdge.
  * @param iSupport
  *   The support defining the hole reference plane.<br>
  *   The following @href CATIABoundary object is supported: 
  *   @href CATIAFace.
  * @param iDepth
  *   The hole depth.
  * @return The created hole
  */
  HRESULT AddNewHoleWithConstraint (
    in double iX, in double iY, in double iZ,
    in CATIAReference iEdge,
    in CATIAReference iSupport,
    in double         iDepth,
    out /*IDLRETVAL*/ CATIAHole oNewHole
    );
  /**
  * Creates and returns a new hole within the current shape.
  * <br>
  * Actual hole shape is defined by editing hole properties after its
  * creation.
  * @param iX
  *   Origin point x absolute coordinate
  * @param iY
  *   Origin point y absolute coordinate
  * @param iZ
  *   Origin point z absolute coordinate
  *   <br>
  *   Sets the origin point which the hole is anchored to.<br> 
  *   If mandatory, the entry point will be projected onto a tangent plane.
  * @param iEdge
  *   The edge which the hole is constrained to.
  *   <br>
  *   The origin of the hole will have a length constraint with
  *   each edge.<br>
  *   The following @href CATIABoundary object is supported: 
  *   @href CATIATriDimFeatEdge.
  * @param iSupport
  *   The support defining the hole reference plane.<br>
  *   The following @href CATIABoundary object is supported: 
  *   @href CATIAFace.
  * @param iDepth
  *   The hole depth.
  * @return The created hole
  */
  HRESULT AddNewHoleWith2Constraints (
    in double iX, in double iY, in double iZ,
    in CATIAReference iEdge1,
    in CATIAReference iEdge2,
    in CATIAReference iSupport,
    in double         iDepth,
    out /*IDLRETVAL*/ CATIAHole oNewHole
    );

  /**
  * Creates and returns a new hole within the current shape.
  * <br>
  * Actual hole shape is defined by editing hole properties after its
  * creation.
  * @param iSketch
  *   The sketch defining the hole reference plane and anchor point.
  *   <br>
  *   This sketch must contain a single point that defines the hole axis: 
  *   the hole axis in 3D passes through that point and is normal to the 
  *   sketch plane.
  * @param iDepth
  *   The hole depth.
  * @return The created hole
  */
  HRESULT AddNewHoleFromSketch (in CATIASketch iSketch,
    in double      iDepth,
    out /*IDLRETVAL*/ CATIAHole oNewHole);

  //  ---------------------------
  //  --  R E V O L  CREATION  --
  //  ---------------------------
  //
  //  ADD A NEW SHAFT
  //  ---------------
  //
  /**
  * Creates and returns a new shaft within the current body.
  * <br>
  * The @href CATIARevolution, as a supertype for shafts,
  * provides starting and ending angles for the shaft definition.
  * <br>
  * @param iSketch
  *   The sketch defining the shaft section. 
  *   <ul>
  *      <li>If the shaft applies to the current body,
  *          then the sketch must contain
  *          a contour and an axis that will be used to rotate 
  *          the contour in the space, thus defining the shaft.
  *      <li>If the shaft is the first shape defined, there is not current 
  *          body to apply to. In such a case, the sketch must contain a curve
  *          whose end points are linked by an axis. By rotating the 
  *          curve in the space around the axis, the shaft operation will define 
  *          a revolution shape.
  *          This also works if the sketch contains a closed contour and
  *          an axis outside of this contour: in that case a revolution 
  *          shape will be created, for example a torus.
  *   </ul>
  * @return The created shaft
  */
  HRESULT AddNewShaft ( in    CATIASketch iSketch
    , out /*IDLRETVAL*/ CATIAShaft  oNewShaft
    );

  //
  //  ADD A NEW GROOVE
  //  ----------------
  //
  /**
  * Creates and returns a new groove within the current body.
  * <br>
  * The @href CATIARevolution, as a supertype for grooves,
  * provides starting and ending angles
  * for the groove definition.
  * @param iSketch
  *   The sketch defining the groove section.
  *   The sketch must contain
  *   a contour and an axis that will be used to rotate 
  *   the contour in the space, thus defining the groove. The contour has to 
  *   penetrate in 3D space the current shape.
  * @return The created groove
  */
  HRESULT AddNewGroove    ( in    CATIASketch iSketch
    , out /*IDLRETVAL*/ CATIAGroove oNewGroove
    );


  //
  //  ADD A NEW SHAFT FROM REFERENCE
  //  ----------------------------
  //
  /**
  * Creates and returns a new shaft within the current body.
  * @param iProfileElt
  *   The reference on the element defining the shaft base
  * @return The created shaft
  */
  HRESULT AddNewShaftFromRef   ( in    CATIAReference iProfileElt
    , out /*IDLRETVAL*/ CATIAShaft oNewShaft
    );


  //
  //  ADD A NEW GROOVE FROM REFERENCE
  //  -------------------------------
  //
  /**
  * Creates and returns a new groove within the current body.
  * @param iProfileElt
  *   The reference on the element defining the groove base
  * @return The created groove
  */
  HRESULT AddNewGrooveFromRef    ( in    CATIAReference iProfileElt
    , out /*IDLRETVAL*/ CATIAGroove oNewGroove
    );

  //  ---------------------------
  //  --  THREAD/TAP  CREATION  --
  //  ---------------------------
  //
  //  ADD A NEW THREAD/TAP
  //  --------------------
  //
  /**
  * Creates and returns a new thread\tap within the current body.
  * @param iLateralFace
  *   The Face defining the support of thread\tap<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iLimitFacee
  *   The Face defining the origin of the thread.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAPlanarFace.
  * @return The created Thread
  */
  HRESULT AddNewThreadWithRef   ( in    CATIAReference iLateralFace
    , in    CATIAReference iLimitFace
    , out /*IDLRETVAL*/ CATIAThread    oNewThread  );


  /**
  * Creates and returns a new thread\tap within the current body.
  * @return The created Thread
  */
  HRESULT AddNewThreadWithOutRef   (out /*IDLRETVAL*/ CATIAThread    oNewThread  );

  //  ---------------------------
  //  --  S W E E P  CREATION  --
  //  ---------------------------
  //
  //  ADD A NEW RIB
  //  -------------
  //
  /**
  * Creates and returns a new rib within the current body.
  * @param iSketch
  *   The sketch defining the rib section
  * @param iCenterCurve
  *   The sketched curve that defines the rib center curve. It must cross the 
  *   section definition sketch <tt>iSketch</tt> within the inner part of 
  *   its contour.
  * @return The created rib
  */
  HRESULT AddNewRib   ( in    CATIASketch iSketch
    , in    CATIASketch iCenterCurve
    , out /*IDLRETVAL*/ CATIARib    oNewRib
    );

  /**
  * Creates and returns a new rib within the current body.
  * @param iProfile
  *   The Profile defining the rib section
  * @param iCenterCurve
  *   The curve that defines the rib center curve.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIATriDimFeatEdge.
  * @return The created rib
  */
  HRESULT AddNewRibFromRef   ( in    CATIAReference iProfile
    , in    CATIAReference iCenterCurve
    , out /*IDLRETVAL*/ CATIARib    oNewRib
    );

  //
  //  ADD A NEW SLOT
  //  --------------
  //

  /**
  * Creates and returns a new slot within the current shape.
  * <br>
  * @param iSketch
  *   The sketch defining the slot section 
  * @param iCenterCurve
  *   The sketched curve that defines the slot center curve. It must cross the 
  *   section definition sketch <tt>iSketch</tt> within the inner part of 
  *   its contour.
  * @return The created slot
  */
  HRESULT AddNewSlot  ( in    CATIASketch iSketch
    , in    CATIASketch iCenterCurve
    , out /*IDLRETVAL*/ CATIASlot   oNewSlot
    );
  /**
  * Creates and returns a new slot within the current shape.
  * <br>
  * @param iProfile
  *   The sketch defining the slot section 
  * @param iCenterCurve
  *   The curve that defines the slot center curve.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIATriDimFeatEdge.
  * @return The created slot
  */
  HRESULT AddNewSlotFromRef  ( in    CATIAReference iProfile
    , in    CATIAReference iCenterCurve
    , out /*IDLRETVAL*/ CATIASlot   oNewSlot
    );


  //
  //  ADD A NEW STIFFENER
  //  -------------------
  //

  /**
  * Creates and returns a new stiffener within the current body.
  * <br>
  * A stiffener is made up of a sketch used as the stiffener profile,
  * that is extruded (offset) and that fills the nearest shape.
  * @param iSketch
  *   The sketch defining the stiffener border. It must contain a 
  *   line or a curve that does not cross in 3D space the face(s) to stiffen.
  * @return The created stiffener
  */
  HRESULT AddNewStiffener ( in    CATIASketch iSketch
    , out /*IDLRETVAL*/ CATIAStiffener  oNewStifffener
    );

  //
  //  ADD A NEW STIFFENER FROM REFERENCE
  //  ----------------------------
  //
  /**
  * Creates and returns a new stiffener within the current body.
  * @param iProfileElt
  *   The reference on the element defining the stiffener profile
  * @return The created stiffener
  */
  HRESULT AddNewStiffenerFromRef   ( in    CATIAReference iProfileElt
    , out /*IDLRETVAL*/ CATIAStiffener oNewStiffener
    );


  //      --------------------------------------------------------
  //      -- C O N T E X T U A L  F E A T U R E S  C R E A T I O N
  //      --------------------------------------------------------

  //      ADD A NEW SCALING FEATURE
  //      -------------------------
  //
  /**
  * @section Contextual shapes
  */

  /**
  * Creates and returns a new scaling within the current body.
  * @param iScalingReference
  *   The point, plane or  face of the current body  that will remain
  *   fixed during the 
  *   scaling process: even if the face itself shrinks or expands during the 
  *   scaling, its supporting plane will remain unchanged after the scaling.<br>
  *   The following @href CATIABoundary objects are supported: 
  *   @href CATIAPlanarFace and @href CATIAVertex.
  * @param iFactor
  *   The scaling factor
  * @return The created scaling
  */
  HRESULT AddNewScaling   ( in CATIAReference iScalingReference
    , in double                 iFactor
    , out /*IDLRETVAL*/ CATIAScaling    oNewScaling
    );

  //  -----------------------------
  //  --  F I L L E T  CREATION  --
  //  -----------------------------
  //
  //  ADD A NEW FACE FILLET
  //  ---------------------
  //
  /**
  * @deprecated V5R14 #AddNewFaceFillet
  * use AddNewSolidFaceFillet or AddNewSurfaceFaceFillet 
  * depending on the type of fillet you want to create
  */
  HRESULT AddNewFaceFillet( in    CATIAReference                  iF1
    , in    CATIAReference                  iF2 
    , in    double              iRadius
    , out /*IDLRETVAL*/ CATIAFaceFillet oNewFillet
    );


  //
  //  ADD A NEW EDGE FILLET (CONSTANT RADIUS)
  //  ---------------------------------------
  //
  /**
  * @deprecated V5R14 #AddNewEdgeFilletWithConstantRadius
  * use AddNewSolidEdgeFilletWithConstantRadius or AddNewSurfaceEdgeFilletWithConstantRadius 
  * depending on the type of fillet you want to create
  */
  HRESULT AddNewEdgeFilletWithConstantRadius
    ( in    CATIAReference                          iEdgeToFillet
    , in    CatFilletEdgePropagation        iPropagMode
    , in    double                  iRadius
    , out /*IDLRETVAL*/ CATIAConstRadEdgeFillet     oNewFillet
    );


  //
  //  ADD A NEW EDGE FILLET (VARYING RADIUS)
  //  --------------------------------------
  //
  /**
  * @deprecated V5R14 #AddNewEdgeFilletWithVaryingRadius
  * use AddNewSolidEdgeFilletWithVaryingRadius or AddNewSurfaceEdgeFilletWithVaryingRadius 
  * depending on the type of fillet you want to create
  */

  HRESULT AddNewEdgeFilletWithVaryingRadius
    ( in    CATIAReference                          iEdgeToFillet
    , in    CatFilletEdgePropagation        iPropagMode
    , in    CatFilletVariation          iVariationMode
    , in    double                  iDefaultRadius
    , out /*IDLRETVAL*/ CATIAVarRadEdgeFillet       oNewFillet
    );


  //
  //  ADD A NEW TRITANGENT FILLET
  //  ---------------------------
  //
  /**
  * @deprecated V5R14 #AddNewTritangentFillet
  * use AddNewSolidTritangentFillet or AddNewSurfaceTritangentFillet 
  * depending on the type of fillet you want to create
  */

  HRESULT AddNewTritangentFillet
    ( in    CATIAReference                          iF1
    , in    CATIAReference                          iF2 
    , in    CATIAReference                          iRemovedFace
    , out /*IDLRETVAL*/ CATIATritangentFillet   oNewFillet
    );
  //
  //      ADD A NEW DRAFT
  //      ---------------
  //
  /**
  * Creates and returns a new draft within the current body.
  * <br>
  * The draft needs a reference face on the body. This face will remain 
  * unchanged in the draft operation, while faces adjacent to it 
  * and specified for drafting will be rotated by the draft angle.
  * @param iFaceToDraft
  *   The first face to draft in the body. This face should be adjacent to the 
  *   <tt>iFaceToDraft</tt> face. If several faces are to be drafted, only the 
  *   first one is specified here, the others being inferred by propagating the
  *   draft operation onto faces adjacent to this first face. This is 
  *   controlled by the <tt>iNeutralMode</tt> argument.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iNeutral
  *   The reference face for the draft. The draft needs a reference face on 
  *   the body, that will remain unchanged in the draft operation, while faces
  *   adjacent to it and specified for drafting will be rotated according 
  *   to the draft angle <tt>iAngle</tt>.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAPlanarFace.
  * @param iNeutralMode
  *   Controls if and how the drafting operation should be propagated beyond the 
  *   first face to draft <tt>iFaceToDraft</tt> to other adjacent faces. 
  * @param iParting 
  *   The draft parting plane, face or surface.
  *   It specifies the element within the body to draft 
  *   that represents the bottom of the mold. This element can be located either
  *   somewhere in the middle of the body or be one of its boundary faces. 
  *   When located in the middle of the body, it crosses the faces to draft, 
  *   and as a result, those faces are drafted with a positive angle on one 
  *   side of the parting surface, and with a negative angle on the other side.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAPlanarFace.
  * @param iDirX,iDirY,iDirZ
  *   The X, Y, and Z components of the absolute vector representing the drafting
  *   direction (i.e. the mold extraction direction).
  * @param iMode
  *   The draft connecting mode to its reference face <tt>iFaceToDraft</tt>
  * @param iAngle
  *   The draft angle
  * @param iMultiselectionMode.
  * The elements to be drafted can be selected explicitly
  * or can implicitly selected as neighbors of the neutral face
  * @return The created draft
  */
  HRESULT AddNewDraft
    ( in CATIAReference                     iFaceToDraft
    , in CATIAReference                     iNeutral
    , in CatDraftNeutralPropagationMode     iNeutralMode
    , in CATIAReference                     iParting
    , in double                             iDirX
    , in double                             iDirY
    , in double                             iDirZ
    , in CatDraftMode                       iMode
    , in double                             iAngle
    , in CatDraftMultiselectionMode       iMultiselectionMode
    , out /*IDLRETVAL*/ CATIADraft         oNewDraft);



  //
  //      ADD A NEW VOLUMIC DRAFT
  //      ---------------
  //
  /**
  * Creates and returns a new volume draft within the current body.
  * <br>
  * The draft needs a reference face on the body. This face will remain 
  * unchanged in the draft operation, while faces adjacent to it 
  * and specified for drafting will be rotated by the draft angle.
  * @param iFaceToDraft
  *   The first face to draft in the body. This face should be adjacent to the 
  *   <tt>iFaceToDraft</tt> face. If several faces are to be drafted, only the 
  *   first one is specified here, the others being inferred by propagating the
  *   draft operation onto faces adjacent to this first face. This is 
  *   controlled by the <tt>iNeutralMode</tt> argument.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iNeutral
  *   The reference face for the draft. The draft needs a reference face on 
  *   the body, that will remain unchanged in the draft operation, while faces
  *   adjacent to it and specified for drafting will be rotated according 
  *   to the draft angle <tt>iAngle</tt>.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAPlanarFace.
  * @param iNeutralMode
  *   Controls if and how the drafting operation should be propagated beyond the 
  *   first face to draft <tt>iFaceToDraft</tt> to other adjacent faces. 
  * @param iParting 
  *   The draft parting plane, face or surface.
  *   It specifies the element within the body to draft 
  *   that represents the bottom of the mold. This element can be located either
  *   somewhere in the middle of the body or be one of its boundary faces. 
  *   When located in the middle of the body, it crosses the faces to draft, 
  *   and as a result, those faces are drafted with a positive angle on one 
  *   side of the parting surface, and with a negative angle on the other side.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAPlanarFace.
  * @param iDirX,iDirY,iDirZ
  *   The X, Y, and Z components of the absolute vector representing the drafting
  *   direction (i.e. the mold extraction direction).
  * @param iMode
  *   The draft connecting mode to its reference face <tt>iFaceToDraft</tt>
  * @param iAngle
  *   The draft angle
  * @param iMultiselectionMode.
  * The elements to be drafted can be selected explicitly
  * or can implicitly selected as neighbors of the neutral face
  * @param iType
  *   The mode of draft creation (4=Volume)
  * @param iVolumeSupport
  *   The support volume for volumic draft
  * @return The created draft
  */
  HRESULT AddNewVolumicDraft
    ( in CATIAReference                     iFaceToDraft
    , in CATIAReference                     iNeutral
    , in CatDraftNeutralPropagationMode     iNeutralMode
    , in CATIAReference                     iParting
    , in double                             iDirX
    , in double                             iDirY
    , in double                             iDirZ
    , in CatDraftMode                       iMode
    , in double                             iAngle
    , in CatDraftMultiselectionMode       iMultiselectionMode
    , in long								iType
    , in CATIAReference						iVolumeSupport
    , out /*IDLRETVAL*/ CATIADraft         oNewDraft);

  //
  //      ADD A NEW SHELL
  //      ---------------
  //
  /**
  * Creates and returns a new shell within the current body.
  * @param iFaceToRemove
  *   The first face to be removed in the shell process.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iInternalThickness
  *   The thickness of material to be added on the internal side of all the faces
  *   during the shell process, except for those to be removed
  * @param iExternaThickness
  *   The thickness of material to be added on the external side of all the faces
  *   during the shell process, except for those to be removed
  * @return The created shell
  */
  HRESULT AddNewShell
    ( in CATIAReference             iFaceToRemove
    , in double                     iInternalThickness
    , in double                     iExternalThickness
    , out /*IDLRETVAL*/ CATIAShell  oNewShell
    );
  //
  //      ADD A NEW THICKNESS
  //      -------------------
  //
  /**
  * Creates and returns a new thickness within the current body.
  * @param iFaceToThicken
  *   The first face to thicken in the thickening process.   
  *   <br>
  *   New faces to thicken can be added to the thickness afterwards by using 
  *   methods offered by the created thickness<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAFace.
  * @param iOffset
  *   The thickness of material to be added on the external side of the face
  *   <tt>iFaceToThicken</tt> during the thickening process
  * @return The created thickness
  */
  HRESULT AddNewThickness
    ( in CATIAReference                iFaceToThicken
    , in double                        iOffset
    , out /*IDLRETVAL*/ CATIAThickness oNewThickness
    );

  //
  //      ADD A NEW CHAMFER
  //      -----------------
  //
  /**
  * Creates and returns a new chamfer within the current body.
  * <br>
  * @param iObjectToChamfer
  *   The first edge or face to chamfer<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIATriDimFeatEdge.
  * @param iPropagation
  *   Controls if and how the chamfering operation should propagate beyond the 
  *   first chamfer element <tt>iObjectToChamfer</tt>, when it is an edge
  * @param iMode
  *   Controls if the chamfer is defined by two lengthes, or by an angle and a 
  *   length
  *   <br>
  *   The value of this argument changes the way the arguments <tt>iLength1</tt>
  *   and <tt>iLength2OrAngle</tt> should be interpreted.
  * @param iOrientation
  *   Defines the relative meaning of arguments <tt>iLength1</tt> and 
  *   <tt>iLength2OrAngle</tt> when defining a chamfer by two lengthes
  * @param iLength1
  *   The first value for chamfer dimensioning. It represents the chamfer 
  *   first length if the chamfer is defined by two lengthes, or the chamfer
  *   length if the chamfer is defined by a length and an angle. 
  * @param iLength2OrAngle
  *   The second value for chamfer dimensioning. It represents the chamfer 
  *   second length if the chamfer is defined by two lengthes, or the chamfer
  *   angle if the chamfer is defined by a length and an angle. 
  * @return The created chamfer
  */
  HRESULT AddNewChamfer
    ( in CATIAReference              iObjectToChamfer
    , in CatChamferPropagation       iPropagation
    , in CatChamferMode              iMode
    , in CatChamferOrientation       iOrientation
    , in double                      iLength1
    , in double                      iLength2OrAngle
    , out /*IDLRETVAL*/ CATIAChamfer oNewChamfer);

  //      ----------------------------------------------------------------
  //      -- T R A N S F O R M A T I O N  F E A T U R E S  C R E A T I O N
  //      ----------------------------------------------------------------
  ///**
  // * @sectionTransformation-based shapes 
  // */



  //      ADD A NEW MIRROR FEATURE
  //      ------------------------
  //

  /**
  * Creates and returns a new mirror within the current body.
  * <br>
  * A mirror allows for transforming existing shapes by a symmetry
  * with respect to an existing plane.
  * @param iMirroringElement
  *   The plane used by the mirror as the symmetry plane.<br>
  * The following @href CATIABoundary object is supported: 
  * @href CATIAPlanarFace.
  * @return The created mirror
  */
  HRESULT AddNewMirror
    ( in CATIAReference       iMirroringElement
    , out /*IDLRETVAL*/ CATIAMirror   oNewMirror
    );

  //      ADD A NEW RECTANGULAR PATTERN
  //      -----------------------------
  //
  /**
  * Creates and returns a new rectangular pattern within the current body.
  * @param iShapeToCopy
  *   The shape to be copied by the rectangular pattern
  * @param iNbOfCopiesInDir1
  *   The number of times <tt>iShapeToCopy</tt> will be copied along
  *   the pattern first direction
  * @param iNbOfCopiesInDir2
  *   The number of times <tt>iShapeToCopy</tt> will be copied along
  *   the pattern second direction
  * @param iStepInDir1
  *   The distance that will separate two consecutive copies in the pattern
  *   along its first direction
  * @param iStepInDir2
  *   The distance that will separate two consecutive copies in the pattern
  *   along its second direction
  * @param iShapeToCopyPositionAlongDir1
  *   Specifies the position of the original shape <tt>iShapeToCopy</tt>
  *   among its copies along <tt>iDir1</tt>
  * @param iShapeToCopyPositionAlongDir2
  *   Specifies the position of the original shape <tt>iShapeToCopy</tt>
  *   among its copies along <tt>iDir2</tt>
  * @param iDir1
  *   The line or linear edge that specifies the pattern first repartition
  *   direction<br>
  * The following @href CATIABoundary objects are supported: 
  * @href CATIAPlanarFace, @href CATIARectilinearTriDimFeatEdge, @href CATIARectilinearBiDimFeatEdge.
  * @param iDir2
  *   The line or linear edge that specifies the pattern second repartition
  *   direction<br>
  * The following @href CATIABoundary objects are supported: 
  * @href CATIAPlanarFace, @href CATIARectilinearTriDimFeatEdge, @href CATIARectilinearBiDimFeatEdge.
  * @param iIsReversedDir1
  *   The boolean flag indicating whether the natural orientation of
  *   <tt>iDir1</tt> should be used to orient the pattern operation.
  *   True indicates that <tt>iShapeToCopy</tt> is copied in the
  *   direction of the natural orientation of <tt>iDir1</tt>.
  * @param iIsReversedDir2
  *   The boolean flag indicating whether the natural orientation of 
  *   <tt>iDir2</tt> should be used to orient the pattern operation.
  *   True indicates that <tt>iShapeToCopy</tt> is copied in the 
  *   direction of the natural orientation of <tt>iDir2</tt>.
  * @param iRotationAngle
  *   The angle applied to both directions <tt>iDir1</tt> and <tt>iDir2</tt>
  *   prior to applying the pattern. 
  *   The original shape <tt>iShapeToCopy</tt> is used as the rotation center.
  *   Nevertheless, the copied shapes themselves are not rotated.
  *   This allows the definition of a rectangular pattern 
  *   relatively to existing geometry, but not necessarily parallel to it.
  * @return The created rectangular pattern
  */ 

  HRESULT AddNewRectPattern
    ( in CATIABase                   	iShapeToCopy
    , in long				iNbOfCopiesInDir1
    , in long				iNbOfCopiesInDir2
    , in double				iStepInDir1
    , in double				iStepInDir2
    , in long				iShapeToCopyPositionAlongDir1
    , in long				iShapeToCopyPositionAlongDir2
    , in CATIAReference			iDir1
    , in CATIAReference			iDir2
    , in boolean				iIsReversedDir1
    , in boolean				iIsReversedDir2
    , in double				iRotationAngle
    , out /*IDLRETVAL*/ CATIARectPattern	oNewRectPattern
    );
  //                        ( in CATIABase                      iItemToDuplicate
  //            , in long               iNbOfInstancesInDir1
  //            , in long               iNbOfInstancesInDir2
  //            , in double             iStepInDir1
  //            , in double             iStepInDir2
  //            , in long               iAnchorRowInDir1 
  //            , in long               iAnchorRowInDir2 
  //                        , in CATIAReference         iDir1
  //                        , in CATIAReference         iDir2
  //            , in boolean                iIsReversedDir1
  //            , in boolean                iIsReversedDir2
  //            , in double             iRotationAngle
  //                        , out /*IDLRETVAL*/ CATIARectPattern    oNewRectPattern
  //                        );

