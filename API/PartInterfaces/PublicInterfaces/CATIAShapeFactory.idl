  HRESULT AddNewReplaceFace(in CATIAReference iSplitPlane,
    in CATIAReference iRemoveFace,
    in CatSplitSide iSplittingSide, 
    out /*IDLRETVAL*/ CATIAReplaceFace oNewReplaceFace);
