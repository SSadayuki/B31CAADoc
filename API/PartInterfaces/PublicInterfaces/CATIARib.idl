#include "CATIASweep.idl"

/**
 * Represents the rib shape.
 * The rib shape is made up of a profile represented by a sketch
 * swept along a center curve represented by another sketch.
 * This is a "positive" shape: it adds material to the body it belongs to.
 */
//-----------------------------------------------------------------
interface CATIARib : CATIASweep
{
	//		================
	//		== PROPERTIES ==
	//		================



	//		=============
	//		== METHODS ==
	//		=============
};

// Interface name : CATIARib
#pragma ID CATIARib "DCE:fd82d46b-5c10-11d1-a2750000f87546fd"
#pragma DUAL CATIARib

// VB object name : Rib (Id used in Visual Basic)
#pragma ID Rib "DCE:fdf2e2f1-5c10-11d1-a2750000f87546fd"
