#ifndef CATIAJoint_IDL
#define CATIAJoint_IDL
/*IDLREP*/

/**
 * @CAA2Level L1
 * @CAA2Usage U3
 */

/**
  * Interface to manage the Joint object.
  * Depending on their type, joints have parameters or not, representing length or angle:
     * <table>
     *  <tr><td><b>Joint type</b></td> <td><b>Parameter1</b></td>  <td><b>Parameter2</b></td></tr>
     *  <tr><td>Revolute</td>          <td>Angle</td>              <td> </td>                </tr>
     *  <tr><td>Prismatic</td>         <td>Length</td>             <td> </td>                </tr>
     *  <tr><td>Cylindrical</td>       <td>Length</td>             <td>Angle</td>            </tr> 
     *  <tr><td>Screw</td>             <td>Length</td>             <td>Angle</td>            </tr> 
     *  <tr><td>Gear</td>              <td>Angle</td>              <td>Angle</td>            </tr>
     *  <tr><td>Rack</td>              <td>Length</td>             <td>Angle</td>            </tr>
     *  <tr><td>Cable</td>             <td>Length</td>             <td>Length</td>           </tr>
     *  <tr><td>PointOnCurve</td>      <td>Length</td>             <td> </td>                </tr>
     *  <tr><td>RollCurve</td>         <td>Length</td>             <td> </td>                </tr>
     * </table>
  * <p>Each parameter can have a lower and/or an upper limit. 
  * <p>Methods are provided to set, unset and return the limits for each parameter.
  */

#include "CATIABase.idl"

interface CATIAJoint : CATIABase
{
   /**
     * Returns the joint type.
     * @param oType 
     *    The type of the joint
     * This property is read only because the construction of the object depends on the type.
     */
#pragma PROPERTY Type
HRESULT get_Type (inout /*IDLRETVAL*/ CATBSTR oType);

   /**
     * Gets the joint current value for first parameter.
     * @param oCurrentValue
     * This property is read only because current value modification is done by solver
     */
#pragma PROPERTY CurrentValue1
HRESULT get_CurrentValue1 (inout /*IDLRETVAL*/ double oCurrentValue);

   /**
     * Gets the joint current value for second parameter.
     * @param oCurrentValue
     * This property is read only because current value modification is done by solver
     */
#pragma PROPERTY CurrentValue2
HRESULT get_CurrentValue2 (inout /*IDLRETVAL*/ double oCurrentValue);

   /**
     * Gets or returns the lower limit of the joint, for the first parameter.
     * @param iLimitValue 
     *    The value for the limit
     * When reading, an error is returned if the joint type has no such parameter, or if the limit is unset.
     */
#pragma PROPERTY LowerLimit1
HRESULT get_LowerLimit1 (inout /*IDLRETVAL*/ double oLimitValue);
HRESULT put_LowerLimit1 (in double iLimitValue);

   /**
     * Unsets the lower limit of the joint, for the first parameter.
     * @param iLimitValue 
     *    The value for the limit
     * When reading, an error is returned if the joint type has no such parameter, or if the limit is unset.
     */
HRESULT UnsetLowerLimit1 ();

   /**
     * Gets or returns the lower limit of the joint, for the second parameter.
     * @param iLimitValue 
     *    The value for the limit
     * When reading, an error is returned if the joint type has no such parameter, or if the limit is unset.
     */
#pragma PROPERTY LowerLimit2
HRESULT get_LowerLimit2 (inout /*IDLRETVAL*/ double oLimitValue);
HRESULT put_LowerLimit2 (in double iLimitValue);

   /**
     * Unsets the lower limit of the joint, for the second parameter.
     * @param iLimitValue 
     *    The value for the limit
     */
HRESULT UnsetLowerLimit2 ();

   /**
     * Gets or returns the upper limit of the joint, for the first parameter.
     * @param iLimitValue 
     *    The value for the limit
     * When reading, an error is returned if the joint type has no such parameter, or if the limit is unset.
     */
#pragma PROPERTY UpperLimit1
HRESULT get_UpperLimit1 (inout /*IDLRETVAL*/ double oLimitValue);
HRESULT put_UpperLimit1 (in double iLimitValue);

   /**
     * Unsets the upper limit of the joint, for the first parameter.
     * @param iLimitValue 
     *    The value for the limit
     */
HRESULT UnsetUpperLimit1 ();

   /**
     * Gets or returns the upper limit of the joint, for the second parameter.
     * @param iLimitValue 
     *    The value for the limit
     * When reading, an error is returned if the joint type has no such parameter, or if the limit is unset.
     */
#pragma PROPERTY UpperLimit2
HRESULT get_UpperLimit2 (inout /*IDLRETVAL*/ double oLimitValue);
HRESULT put_UpperLimit2 (in double iLimitValue);

   /**
     * Unsets the upper limit of the joint, for the second parameter.
     * @param iLimitValue 
     *    The value for the limit
     */
HRESULT UnsetUpperLimit2 ();

};


