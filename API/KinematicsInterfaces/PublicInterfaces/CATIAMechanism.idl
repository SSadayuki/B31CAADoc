#ifndef CATIAMechanism_IDL
#define CATIAMechanism_IDL
/*IDLREP*/

/**
 * @CAA2Level L1
 * @CAA2Usage U3
 */

#include "CATIABase.idl"

#include "CATIAJoints.idl"
#include "CATIAMechanismCommands.idl"
#include "CATIAProduct.idl"
#include "CATIAProducts.idl" 

  /** 
    * Interface to access the Mechanism object.
    */	

interface CATIAMechanism : CATIABase
{
#pragma PROPERTY NbProducts

   /** 
     * Returns the number of products (i.e. bodies) involved in the mechanism.
     * @param oNbProducts
     *    The number of products.
     * This property is read only because number depends on joints creation/destruction
     */
HRESULT get_NbProducts (inout /*IDLRETVAL*/ long oNbProducts);

#pragma PROPERTY NbJoints
   /** 
     * Returns the number of joints in the mechanism.
     * @param oNbJoints
     *    The number of joints.
     * This property is read only because number depends on joints creation/destruction
     */
HRESULT get_NbJoints (inout /*IDLRETVAL*/ long oNbJoints);

#pragma PROPERTY Joints
   /** 
     * Returns the collection of joints in the mechanism.
     * @param oJoints
     *    The collection of joints.
     * This property is read only because because list is aggregated in the Mechanism 
     */
HRESULT get_Joints(out /*IDLRETVAL*/ CATIAJoints oJoints);

#pragma PROPERTY NbCommands
   /** 
     * Returns the number of commands in the mechanism.
     * @param oNbCommands
     *    The number of commands.
     * This property is read only because number depends on commands creation/destruction
     */
HRESULT get_NbCommands (inout /*IDLRETVAL*/ long oNbCommands);

#pragma PROPERTY Commands
   /** 
     * Returns the collection of commands in the mechanism.
     * @param oCommands
     *    The collection of commands.
     * This property is read only because because list is aggregated in the Mechanism 
     */
HRESULT get_Commands(out /*IDLRETVAL*/ CATIAMechanismCommands oCommands);

#pragma PROPERTY NbDof
   /** 
     * Returns the degree of freedom of the mechanism.
     * @param oNbDof
     *    The degree of freedom.
     * This property is read only because because it depends on joints and commands
     */
HRESULT get_NbDof (inout /*IDLRETVAL*/ long oNbDof);

   /** 
     * Returns or sets the fixed part of the mechanism.
     * @param oFixedPart
     *    The fixed part.
     */
#pragma PROPERTY FixedPart
HRESULT get_FixedPart (out /*IDLRETVAL*/ CATIAProduct oFixedPart);
HRESULT put_FixedPart (in CATIAProduct iFixedPart);


   /** 
     * Adds a joint in the mechanism.
     * @param iJointType
     *    The joint type.
     * @param iListElem
     *    The list of elements expected to locate the joint, depending on the type.
     * @param oNewJoint
     *    The newly created joint.
     */
HRESULT AddJoint (in CATBSTR iJointType, 
                  inout CATSafeArrayVariant iListElem,
                  out /*IDLRETVAL*/ CATIAJoint oNewJoint);

   /** 
     * Adds a command in the mechanism, on a joint.
     * @param iCmdType
     *    The command type.
     * @param iJoint
     *    The joint to be driven.
     * @param oNewCommand
     *    The newly created command.
     */
HRESULT AddCommand (in CATBSTR iCmdType,
                    in CATIAJoint iJoint, 
                    out /*IDLRETVAL*/ CATIAMechanismCommand oNewCommand);


  /**
    * Allows to retrieve current state of the mechanism.
    * @param ioCmdValues
    *    current command values
    */
HRESULT GetCommandValues (inout    CATSafeArrayVariant ioCmdValues);

  /**
    * Triggers immediate mechanism solving.Visualization is updated after solve.
    * @param iCmdValues
    *    command values to be solved for
    */
HRESULT PutCommandValues (in       CATSafeArrayVariant iCmdValues ); 


   /** 
     * Returns an item from the list of the products involved in the mechanism.
     * @param iIndex
     *    The index for the product.
     * @param oProduct
     *    The product at that index.
     * @return
     *    HRESULT
     */
HRESULT  GetProduct (in long iIndex, out /*IDLRETVAL*/ CATIAProduct oProduct);


/**
  * Retrieves motion from initial state to current state for a part
  * of the mechanism.
  *    @param iProduct
  *       The moving product
  *    @param ioMotion
  *       The motion matrix (12 real values, compatible with the Move object)
  *    @see CATIAMove
  */
HRESULT GetProductMotion (in CATIAProduct iProduct, inout CATSafeArrayVariant ioMotion );


  /**
    * Reassembles the mechanism after dimension changes in the parts.
    */
HRESULT Update( );

  /** 
    * Puts command values in given number of steps. Visualization is updated after every step.
    * @param iCmdValues
    *    Array of target command values (position to achieve)
    * @param inbSteps
    *    Number of steps in witch the target command value is to be reached.  
    * <br><b>Legal values </b>
    *  <dl> <dt> inbSteps greater than 0 </dt> <dd> Number of step must be greater than zero.
     * @param oStepReached
     *    Number of steps reached successfully.
    */
HRESULT PutCommandValuesWithMultiSteps(in  CATSafeArrayVariant iCmdValues,
                                       in  long iNbSteps,
                                       out long oStepReached);
 /**
   * Sets the command value to zero for the given command without disturbing part positions.
   * @param iCommand
   *    The command to reset to zero
   */
HRESULT ResetCmdValueToZero (in CATIAMechanismCommand iCommand);


};


// Interface name : CATIAMechanism
#pragma ID CATIAMechanism "DCE:d194ac30-475c-11d4-853900008634168f"
#pragma DUAL CATIAMechanism


// VBScript object name : Mechanism

#pragma ID Mechanism "DCE:d20bdcd0-475c-11d4-853900008634168f"
#pragma ALIAS CATIAMechanism Mechanism 

#endif 

